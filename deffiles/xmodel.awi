	Asset.AddEntry_CheckBox( "heroAsset", false ).SetTitle( "Hero Asset" ) .SetToolTip( "This asset has been generated for a specialized purpose." );	
	Asset.AddEntry_CheckBox( "germanUnsafe", false ).SetTitle( "German Unsafe" ) .SetToolTip( "This asset cannot be used for the German SKU." );	
	Asset.AddEntry_CheckBox( "japaneseUnsafe", false ).SetTitle( "Japanese Unsafe" ) .SetToolTip( "This asset cannot be used for the Japanese SKU." );
	Asset.AddEntry_CheckBox( "arabicUnsafe", false ).SetTitle( "Arabic Unsafe" ) .SetToolTip( "This asset cannot be used for the Arabic SKU." );
	Asset.AddEntry_CheckBox( "forceResident", false ).SetTitle( "Force Resident" ).Show( true );
	Asset.AddEntry_CheckBox( "preserveOriginalUVs", false ).SetTitle( "Preserve Original UVs" ).Show( true );
	
	Asset.BeginCategory("LODs");
	Asset.AddEntry_Combo( "lodPresets", "performance | far detail | near detail | custom" ).SetTitle( "Auto LOD Preset" ).UpdateOnChange( true ).SetToolTip( "Sets default autogenerated LOD values." ).SetValidateCallback("void PresetChanged(asset Asset, const string& ID)");
	
	string dropLodString = "Let Streamer Pick{Auto} | LOD0{High}";
		if ( NumLODs > 1 )  dropLodString += "| LOD1{Medium}";
		if ( NumLODs > 2 )  dropLodString += "| LOD2{Low}";
		if ( NumLODs > 3 )  dropLodString += "| LOD3{Lowest}";

		if ( NumLODs > 4 )  dropLodString += "| LOD4";
		if ( NumLODs > 5 )  dropLodString += "| LOD5";
		if ( NumLODs > 6 )  dropLodString += "| LOD6";
		if ( NumLODs > 7 )  dropLodString += "| LOD7";

	Asset.AddEntry_Combo( "dropLOD", dropLodString ).SetTitle( "Max Rendered LOD" ).UpdateOnChange( true ).SetToolTip( "Sets which LOD will be streamed in as the highest LOD." );
	
	//Asset.AddEntry_Float( "cullOutDiameter", 0, 0, 10000.0 ).SetStep(0.25).SetTitle( "Cull Out Diameter " ).SetToolTip( "Stop drawing this model if its on-screen pixel diamter is less than this value." ).Show( true ).Enable( true );
	//Asset.AddEntry_Float( "LODBiasPercent", 1, -2.0, 20.0 ).SetStep(0.25).SetTitle( "LOD Bias " ).SetToolTip( "Modifies calculation for when switching of LODs occurs. Default is '0'" ).Show( true ).Enable( true );

	Asset.AddEntry_Vector3(  "cullOutDiameter", "cullOutOffsetMP",  "cullOutOffsetCP",  0.0, 1, 1.0, 0, 1000 ).SetTitle( "Cull Out Diameter" ).SetStep( 0.25f ).SetLabels( "Base Value",     "              Multipliers:      [ Detail ]", "    [ Performance ]", "(Multiply)" ).SetToolTip( "Stop drawing this model if its on-screen pixel diamter is less than this value." );
	Asset.AddEntry_Vector3(  "LODBiasPercent",  "LODBiasOffsetMP", "LODBiasOffsetCP",  0, 0, 0, -4, 20 ).SetTitle( "LOD Bias" ).SetStep( 0.25f ).SetLabels(  "Base Value", "                  Offsets:      [ Detail ]", "    [ Performance ]", "(Offset)" ).SetToolTip( "Modifies calculation for when switching of LODs occurs. Default is '0'" );
	//Asset.AddEntry_CheckBox( "neverDistanceCull", false ).SetTitle( "Never Distance Cull" ).SetToolTip( "Forces this model to never fade out regardless of distance" );

	

	


	
	Asset.AddEntry_ButtonGroup("numLods").AddButton("1", "", "void NumLODsClicked(asset Asset, const string& ID)", "1")
	                                     .AddButton("2", "", "void NumLODsClicked(asset Asset, const string& ID)", "2")
	                                     .AddButton("3", "", "void NumLODsClicked(asset Asset, const string& ID)", "3")
	                                     .AddButton("4", "", "void NumLODsClicked(asset Asset, const string& ID)", "4")
	                                     .AddButton("5", "", "void NumLODsClicked(asset Asset, const string& ID)", "5")
	                                     .AddButton("6", "", "void NumLODsClicked(asset Asset, const string& ID)", "6")
	                                     .AddButton("7", "", "void NumLODsClicked(asset Asset, const string& ID)", "7")
	                                     .AddButton("8", "", "void NumLODsClicked(asset Asset, const string& ID)", "8")
	                                     .AddButton("XModel Info", "$info.png", "void NumLODsClicked(asset Asset, const string& ID)", "info").SetTitle("Number of LODs").SetToolTip("Select the number of LODs");
										 
 	Asset.BeginCategory( "LODs.Custom LOD Parameters" );
 	{
 		Asset.AddEntry_CheckBox( "customAutogenParams", false ).SetTitle( "Use Custom Autogen Vertex Weights" ).SetToolTip( "Tweak the priority weights used to generate autogen LODs." ).UpdateOnChange( true );
 		Asset.AddEntry_Vector4( "lodPositionPriority", "lodNormalPriority", "LodUvPriority", "LodColorPriority", 12.0,1.54,3.5,0.008, 0.0, 32.0 ).SetTitle( "Vertex Weights" ).SetStep( 0.25f ).SetLabels( "Position", "      Normal", "         UV", "  Vert Color" ).Enable( Asset.GetEntryBool( "customAutogenParams" ) );
    }
	
	Asset.BeginCategory( "LODs.LOD 0" );
