		Asset.AddEntry_CheckBox( "DetailShadows", false ).SetTitle( "Enable Detail Shadows" ).SetToolTip( "Will use higher LOD for shadows when lit by Detail Shadow lights" );
		Asset.AddEntry_CheckBox( "noCastShadow", false ).SetTitle( "No Shadow Casting" ).SetToolTip( "Disable shadow casting." ).Enable( true );
	}

	Asset.BeginCategory( "Materials" );
	{
		Asset.AddEntry_Text( "materials", "" ).SetTitle( "Materials" ).ShowJumpTo( true ).SetToolTip( "Display the materials in filename, mediumLOD, lowLOD and lowestLOD files." ).Show( false );
		Asset.AddEntry_Text( "skinOverride", "" ).SetTitle( "Materials" ).ShowJumpTo( true ).SetToolTip( "Enter the name of the new material next to the one you want replaced." );
	}
	
	Asset.BeginCategory( "Attributes" );
	{
		Asset.AddEntry_Path( "CollisionMap", "" ).SetTitle( "Collision Map" ).SetRelativePath( "share/raw/collmaps/" ).SetFileFilter( "Collision Map Files (*.map)" ).SetToolTip( "Specifies the collmap that will be used for this model." );	
		Asset.AddEntry_Path( "hitBoxModel", "" ).SetTitle( "Hit Box Model" ).SetRelativePath( "model_export/" ).SetToolTip( "use this to specify a different hit box for your model." );
		
		Asset.GetEntryControl( "isSiege" ).SetBool( isSiege );
		
		Asset.AddEntry_Text( "boneControllers", "" ).SetTitle( "Bone Controllers" ).SetToolTip( "Used to specify a joint in a model to be controlled programmatically - list the script control first, space, then the joint being controlled will not work without function in script to match" );
		Asset.AddEntry_Text( "boneStabilizers", "" ).SetTitle( "Bone Stabilizers" ).SetToolTip( "see bone controllers" );
		Asset.AddEntry_AssetCombo( "physicsPreset", "physpreset" ).SetTitle( "Physics Preset" ).SetToolTip( "Use this to choose a physics preset file for your model, leave blank for default unmovable object." ).UpdateOnChange( true );
		Asset.AddEntry_AssetCombo( "physicsConstraints", "physconstraints" ).SetTitle( "Physics Constraints" ).SetToolTip( "Use this to choose a physics constraints file for your model." );
		
		Asset.AddEntry_Float( "scale", 1.0, 0, 10 ).SetTitle( "Model Scale" ).SetToolTip( "When converting this model scale it by this amount" ).Show( true );
		Asset.AddEntry_CheckBox( "scaleCollMap", false ).SetTitle( "Scale Collmap" ).Show( true ).SetToolTip( "Apply the model scale to the collmap also" );
		
		Asset.AddEntry_CheckBox( "fp32", false ).SetTitle( "Disable Vertex Quant (PS3 only)" ).Show( false );
		Asset.AddEntry_CheckBox( "heroLighting", false ).SetTitle( "Hero Lighting" ).SetToolTip( "Forces this model to always pick up hero lighting." ).Show(false);
		Asset.AddEntry_CheckBox( "noOutdoorOcclude", false ).SetTitle( "No Outdoor Map Occlusion" ).SetToolTip( "Forces this model not to render into the outdoor map for weather and particles." );
		Asset.AddEntry_CheckBox( "isSiege", false ).SetTitle( "Is Siege" ).SetToolTip( "Is the highest LOD xmodel siege? Can not be edited." ).Enable(false);
	}

	Asset.BeginCategory( "Submodels" );
	{
		for ( int subModelIndex = 0; subModelIndex < 16; subModelIndex++ )
		{
			string prefix = "submodel" + subModelIndex + "_";
			string category = "Submodel #" + (subModelIndex + 1);

			Asset.BeginCategory( "Submodels." + category );
			{
				Asset.AddEntry_AssetCombo( prefix + "Name", "xmodel" ).SetTitle( "Model" );
				Asset.AddEntry_BoneCombo( prefix + "ParentTag", "filename" ).SetTitle( "Parent Tag" );
				Asset.AddEntry_Vector3( prefix + "OffsetX", prefix + "OffsetY", prefix + "OffsetZ", 0, 0, 0, -10000, 10000 ).SetTitle( "Position Offset" ).SetStep( 0.01f ).SetLabels( "Forward", "Right", "Up", "" );
				Asset.AddEntry_Vector3( prefix + "OffsetPitch", prefix + "OffsetYaw", prefix + "OffsetRoll", 0, 0, 0, -180, 180 ).SetTitle( "Angles Offset" ).SetStep( 0.01f ).SetHints( "NOWARNINGS" ).SetLabels( "Pitch  ", "Yaw", "Roll", "" );
			}
		}
	}

	Asset.BeginCategory( "Usage" );
	{
		array<array<string>> usages = {
			{ "weapon", "Weapon", "" },
			{ "attachment", "Attachment", "" },
			{ "hero", "Hero/Specialist", "" },
			{ "view", "View Model", "Used as part of viewarms" },
			{ "zombie_body", "Zombie Body", "Zombie body or body part" },
			{ "zombie_world_prop", "Zombie World Prop", "Zombie prop that is placed in the world by script" }
		};

		for( int idx = 0; idx < usages.length(); idx++ )
		{
			Asset.AddEntry_CheckBox( "usage_" + usages[idx][0], false ).SetTitle( usages[idx][1] ).SetToolTip( usages[idx][2] ).Show( true );
		}
	}
}
