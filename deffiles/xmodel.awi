void ValidateLODs(asset Asset, const string& ID)
{
	array<string> ModelNames = { "filename", "mediumLod", "lowLod", "lowestLod", "lod4File", "lod5File", "lod6File", "lod7File" };
	array<string> DistNames = { "highLodDist", "mediumLodDist", "lowLodDist", "lowestLodDist", "lod4Dist", "lod5Dist", "lod6Dist", "lod7Dist" };
	array<string> AutogenNames = { "", "autogenMediumLod", "autogenLowLod", "autogenLowestLod", "autogenLod4", "autogenLod5", "autogenLod6", "autogenLod7" };
	array<float> Distances;

	for (int EntryIdx = 0; EntryIdx < 8; EntryIdx++)
		Distances.insertLast(Asset.GetEntryFloat(DistNames[EntryIdx]));

	for (int EntryIdx = 1; EntryIdx < 8; EntryIdx++)
	{
		bool Enabled = Asset.GetEntryBool(AutogenNames[EntryIdx]) || Asset.GetEntryValue(ModelNames[EntryIdx]).Length() != 0;
		Asset.GetEntryControl(DistNames[EntryIdx]).SetValid(!Enabled || Distances[EntryIdx - 1] < Distances[EntryIdx] || Distances[EntryIdx] == 0);
	}
}

int GetNumLODs(asset Asset)
{
	array<string> ModelNames = { "filename", "mediumLod", "lowLod", "lowestLod", "lod4File", "lod5File", "lod6File", "lod7File" };
	array<string> AutogenNames = { "", "autogenMediumLod", "autogenLowLod", "autogenLowestLod", "autogenLod4", "autogenLod5", "autogenLod6", "autogenLod7" };
	
	int Levels = -1;
	
	if ( Asset.GetEntryValue( "filename" ) == "" )
	{
		Levels = 8;
		return Levels;
	}
	

	Levels = 1;
	
	for (int EntryIdx = 1; EntryIdx < 8; EntryIdx++)
	{
		if (Asset.GetEntryBool(AutogenNames[EntryIdx]) || Asset.GetEntryValue(ModelNames[EntryIdx]).Length() != 0)
			Levels = EntryIdx + 1;
	}


	return Levels;
}

float GetDetailBias( string Preset, string Mode )
{
	float Bias = 1.0;
	if ( Preset == "far detail" && Mode == "far" )
	{
		Bias = 4.0;
	}
	
	if ( Preset == "near detail" && Mode == "near" )
	{
		Bias = 1.2;
	}
	
	if ( Preset == "mid detail" && Mode == "mid" )
	{
		Bias = 1.25;
	}
	
	return Bias;
}

void ShowLODControls(asset Asset, int Levels, bool ChangeSettings)
{
	Asset.GetEntryControl("highLodDist").Show(false);
	
	bool Unlocked = false;
	if ( Asset.GetEntryValue("lodPresets") == "custom" )
	{
		Unlocked = true;
	}
	
	float farDetail = 1.0;
	float nearDetail = 1.0;
	float midDetail = 1.0; //not implemented
	float LOD_Seed = 50.0;
	
	if (ChangeSettings)
	{
		string LOD_Bias = Asset.GetEntryValue( "lodPresets" );
		nearDetail = GetDetailBias( LOD_Bias, "near" );
		farDetail = GetDetailBias( LOD_Bias, "far" );
	}
	
	Asset.BeginCategory("LODs.LOD 1");
	Asset.GetEntryControl("mediumLod").Show(Levels > 1);
	Asset.GetEntryControl("mediumLodDist").Show(false);
	Asset.GetEntryControl("forceMediumLodRigid").Show(Levels > 1);
	Asset.GetEntryControl("autogenMediumLod").Show(Levels > 1);
	Asset.GetEntryControl("autogenMediumLodPercent").Show(Levels > 1 && Asset.GetEntryBool("autogenMediumLod")).Enable( Unlocked );

	if (ChangeSettings)
	{
		if (Levels < 2)
		{
			Asset.GetEntryControl("mediumLod").SetValue("");
			Asset.GetEntryControl("autogenMediumLod").SetBool(false);
		}
		else if (Asset.GetEntryValue("mediumLod").Length() == 0)
		{
			Asset.GetEntryControl("autogenMediumLod").SetBool(true);
			Asset.GetEntryControl("autogenMediumLodPercent").SetInt( int( LOD_Seed * nearDetail ) );
		}
	}

	Asset.BeginCategory("LODs.LOD 2");
	Asset.GetEntryControl("lowLod").Show(Levels > 2);
	Asset.GetEntryControl("lowLodDist").Show(false);
	Asset.GetEntryControl("forceLowLodRigid").Show(Levels > 2);
	Asset.GetEntryControl("autogenLowLod").Show(Levels > 2);
	Asset.GetEntryControl("autogenLowLodPercent").Show(Levels > 2 && Asset.GetEntryBool("autogenLowLod")).Enable( Unlocked );

	if (ChangeSettings)
	{
		if (Levels < 3)
		{
			Asset.GetEntryControl("lowLod").SetValue("");
			Asset.GetEntryControl("autogenLowLod").SetBool(false);
		}
		else if (Asset.GetEntryValue("lowLod").Length() == 0)
		{
			Asset.GetEntryControl("autogenLowLod").SetBool(true);
			Asset.GetEntryControl("autogenLowLodPercent").SetInt( int( LOD_Seed / 2 * nearDetail ) );
		}
	}

	Asset.BeginCategory("LODs.LOD 3");
	Asset.GetEntryControl("lowestLod").Show( Levels > 3 );
	Asset.GetEntryControl("lowestLodDist").Show(false);
	Asset.GetEntryControl("forceLowestLodRigid").Show(Levels > 3);
	Asset.GetEntryControl("autogenLowestLod").Show(Levels > 3);
	Asset.GetEntryControl("autogenLowestLodPercent").Show(Levels > 3 && Asset.GetEntryBool("autogenLowestLod")).Enable( Unlocked );

	if (ChangeSettings)
	{
		if (Levels < 4)
		{
			Asset.GetEntryControl("lowestLod").SetValue("");
			Asset.GetEntryControl("autogenLowestLod").SetBool(false);
		}
		else if (Asset.GetEntryValue("lowestLod").Length() == 0)
		{
			Asset.GetEntryControl("autogenLowestLod").SetBool(true);
			Asset.GetEntryControl("autogenLowestLodPercent").SetInt( int( ( LOD_Seed / 4 * nearDetail ) + ( LOD_Seed / 4 * ( midDetail - 1.0 ) ) ) );
		}
	}

	int lodPercent = int( LOD_Seed / 8 );

	for (int lodIndex = 4; lodIndex < 8; lodIndex++)
	{
		Asset.BeginCategory("LODs.LOD " + lodIndex);
		Asset.GetEntryControl("lod" + lodIndex + "File").Show(Levels > lodIndex);
		Asset.GetEntryControl("lod" + lodIndex + "Dist").Show(false);
		Asset.GetEntryControl("forceLod" + lodIndex + "Rigid").Show(Levels > lodIndex);
		Asset.GetEntryControl("autogenLod" + lodIndex).Show(Levels > lodIndex);
		Asset.GetEntryControl("autogenLod" + lodIndex + "Percent").Show(Levels > lodIndex && Asset.GetEntryBool("autogenLod" + lodIndex )).Enable( Unlocked );

		if (ChangeSettings)
		{
			if (Levels <= lodIndex)
			{
				Asset.GetEntryControl("lod" + lodIndex + "File").SetValue("");
				Asset.GetEntryControl("autogenLod" + lodIndex).SetBool(false);
			}
			else if (Asset.GetEntryValue("lod" + lodIndex + "File").Length() == 0)
			{
				Asset.GetEntryControl("autogenLod" + lodIndex).SetBool(true);
				Asset.GetEntryControl("autogenLod" + lodIndex + "Percent").SetInt( int( ( lodPercent + farDetail ) + ( lodPercent * ( midDetail - 1.0 ) ) ) );
			}
			lodPercent = lodPercent / 2;
		}
	}
}

void NumLODsClicked(asset Asset, const string& ID)
{
	if (ID == "info")
	{
		ShowXModelInfo(Asset.GetName());
		return;
	}

	int Levels = ID.ToInt();
	Asset.GetEntryControl("numLods").SetInt(Levels);
	ShowLODControls(Asset, Levels, true);
}

void PresetChanged(asset Asset, const string& ID)
{
	int NumLODs;
	if (Asset.GetEntryValue("numLods") == "")
		NumLODs = GetNumLODs(Asset);
	else
		NumLODs = Asset.GetEntryInt("numLods");
		
	string Preset = Asset.GetEntryValue( "lodPresets" );
	
	if ( Preset == "custom" )
	{
		ShowLODControls( Asset, NumLODs, false );
		return;
	}
	else
	{
		ShowLODControls(Asset, NumLODs, true);
	}
}

void GenerateUI( asset Asset )
{

	int NumLODs;
	if (Asset.GetEntryValue("numLods") == "")
		NumLODs = GetNumLODs(Asset);
	else
		NumLODs = Asset.GetEntryInt("numLods");
		
	Asset.SetGraphColor(0.388, 0.251, 0.412, 1.0);
	bool isSiege = IsXModelSiege( Asset.GetEntryValue( "filename" ) );

	Asset.AddEntry_Combo( "type", "rigid | animated | multiplayer body | viewhands" ).SetTitle( "Type" ).UpdateOnChange( true ).SetToolTip( "Rigid is for non-animated objects, animated is for objects that must animate." );
	if( isSiege && Asset.GetEntryValue( "type" ) != "rigid" )
	{
		Asset.AddEntry_Label("siegeModel","This is a siege model, it has to be 'rigid'.").SetTitle(" ").SetIcon( "Icon_ImageMismatch.png");
	}
