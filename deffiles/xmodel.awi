		Asset.AddEntry_XModel( "filename", "" ).SetTitle( "File" ).SetRelativePath( "model_export/" ).UpdateOnChange( true );
		Asset.AddEntry_Float( "highLodDist", 0, 0, 1000000 ).SetStep(50).SetTitle( "Distance" ).SetToolTip( "the default high LOD distance is 250." ).SetValidateCallback("void ValidateLODs(asset Asset, const string& ID)");
