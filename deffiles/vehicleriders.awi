void CopySingleObject( asset Asset, string fromObjectPrefix, string toObjectPrefix )
{
	for ( uint i = 0; i < gObjectKeys.length(); i++ )
	{
		Asset.GetEntryVariable( toObjectPrefix + gObjectKeys[i] ).SetValue( Asset.GetEntryValue( fromObjectPrefix + gObjectKeys[i] ) );
	}
}

void SwapObjects( asset Asset, string objectAPrefix, string objectBPrefix )
{
	array<string> values_temp;
	for ( uint i = 0; i < gObjectKeys.length(); i++ )
	{
		values_temp.insertLast( Asset.GetEntryValue( objectAPrefix + gObjectKeys[i] ) );
	}

	CopySingleObject( Asset, objectBPrefix, objectAPrefix );

	for ( uint i = 0; i < values_temp.length(); i++ )
	{
		Asset.GetEntryVariable( objectBPrefix + gObjectKeys[i] ).SetValue( values_temp[i] );
	}
}

void MoveObjectUp( asset Asset, const string& index )
{
	int n_index = index.ToInt();

	string prefix = "object" + index + "_";
	string prefixPrev = "object" + ( n_index - 1 ) + "_";
	
	bool firstObject = ( n_index == 1 );
	
	if ( !firstObject )
	{
		SwapObjects( Asset, prefixPrev, prefix );
	}
}

void MoveObjectDown( asset Asset, const string& index )
{
	int n_index = index.ToInt();

	string prefix = "object" + index + "_";
	string prefixNext = "object" + ( n_index + 1 ) + "_";
	
	bool lastObject = ( n_index == MAX_SCRIPTBUNDLE_OBJECTS );
	
	if ( !lastObject )
	{
		SwapObjects( Asset, prefix, prefixNext );
	}
}

void CopyObject( asset Asset, const string& index )
{
	int n_index = index.ToInt();

	string prefix = "object" + index + "_";
	string prefixNext = "object" + ( n_index + 1 ) + "_";
	
	// error if there are MAX objects already
	if ( gValidObjectCount != MAX_SCRIPTBUNDLE_OBJECTS )
	{
		// start at end and shift everything down
		for ( int i = MAX_SCRIPTBUNDLE_OBJECTS - 1; i > n_index; i-- )
		{
			string copyFromPrefix = "object" + i + "_";
			string copyToPrefix = "object" + ( i + 1 ) + "_";

			CopySingleObject( Asset, copyFromPrefix, copyToPrefix );
		}

		// copy the object we are copying down to the next object
		CopySingleObject( Asset, prefix, prefixNext );

		Asset.GetEntryVariable( prefixNext + "Position" ).SetValue( Asset.GetEntryValue( prefix + "Position" ) + "(copy)");
	}
	else
	{
		MessageBox( "Cannot copy object, already at max object count!", "OK" );
	}
}

void DeleteObject( asset Asset, const string& index )
{
	string prefix = "object" + index + "_";
	string objectName = "Object " + index;
	
	if ( MessageBox( "Are you sure you want to remove " + objectName + "?", "YESNO" ) == "YES" )
	{
		int n_index = index.ToInt();
		for ( uint i = n_index; i <= MAX_SCRIPTBUNDLE_OBJECTS; i++ )
		{
			string copyFromPrefix = "object" + (i+1) + "_";
			string copyToPrefix = "object" + i + "_";
			
			CopySingleObject( Asset, copyFromPrefix, copyToPrefix );
		}
	}
}
