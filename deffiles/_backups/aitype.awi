			Asset.AddEntry_Float( "favorTraversalFactor", 1.0, 0.1, 10.0 ).SetStep( 0.1 ).SetTitle( "Traversal Favoring" ).SetToolTip( "How much the AI will favor traversals over regular locomotion" ).Enable(  isArchetypeAssetBool || isVariantAssetBool );
			Asset.AddEntry_Float( "favorSpecialTraversalFactor", 1.0, 0.1, 10.0 ).SetStep( 0.1 ).SetTitle( "Special Traversal Favoring" ).SetToolTip( "How much the AI will favor special traversals that match their movementtype" ).Enable(  isArchetypeAssetBool || isVariantAssetBool );
		}
		
		Asset.BeginCategory( "Variant Attributes"+ ".Behaviors", VAR_R, VAR_G, VAR_B, "variant.png" );
		{
			Asset.AddEntry_Combo( "category", "None{0} | Civilian{1} | Assault{2} | CQB{3} | RPG{4} | Sniper{5} | Suppressor{6} | Riot Shield{7}" ).SetTitle( "Tactical Mode Category" ).Enable( isArchetypeAssetBool || isVariantAssetBool ).UpdateOnChange( true );
		
			Asset.AddEntry_CheckBox( "canFlank", false ).SetToolTip( "If set to true, AI will try to choose covernodes, which will flank the enemy." ).SetTitle( "Flank Behavior" ).Enable( isArchetypeAssetBool || isVariantAssetBool ).UpdateOnChange( true );						
			
			Asset.AddEntry_Int( "flankingScoreScale", 1, 1, 5 ).SetTitle( "Flank Score Scale" ).SetToolTip( "Scalar to modify the flanking score of 50 that gets added to the node, bigger the scalar, the more the AI will favor flank." ).Enable( isArchetypeAssetBool || isVariantAssetBool ).Show( Asset.GetEntryBool( "canFlank" ) );				
			Asset.AddEntry_Float( "flankingAngle", 70.0, 50.0, 100.0 ).SetStep( 10.0 ).SetTitle( "Flank Angle" ).SetToolTip( "Unimplemented - The nodes at this angle will be considered for flanking." ).Enable( false ).Show(false);					
						
			Asset.AddEntry_CheckBox( "aggressiveMode", false ).SetToolTip( "If set to true, AI will be aggressive by flushing out the player and throw grenades on the move." ).SetTitle( "Aggressive Behavior" );
			Asset.AddEntry_CheckBox( "accurateFire", false ).SetToolTip( "If set to true, AI will be not blindfire or do any related behaviors." ).SetTitle( "Accurate Fire" );
			Asset.AddEntry_Path( "sniperGlintFX", "" ).SetTitle( "Sniper Glint FX" ).SetToolTip( "Effect to play as a glint on the scope just before the sniper fires" ).SetRelativePath( "share/raw/fx/" ).Enable( isArchetypeAssetBool || isVariantAssetBool ).Show(Asset.GetEntryBool( "accurateFire" ));			
