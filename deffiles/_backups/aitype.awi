const float ARCH_R = 1.0;
const float ARCH_G = 0.5;
const float ARCH_B = 0.3;

const float VAR_R = 0.3;
const float VAR_G = 0.5;
const float VAR_B = 1.0;

const float SPAWN_R = 0.0;
const float SPAWN_G = 0.7;
const float SPAWN_B = 0.1;

const float MISC_R = 0.7;
const float MISC_G = 0.2;
const float MISC_B = 0.7;

const array<string> COVERS = {
	"Crouch",
	"Exposed",
	"Left",
	"Pillar",
	"Right",
	"Stand"
};

const array<string> STEERING = {
	"Normal",
	"Slow",
	"Vignette"
};

const array<string> STEERING_PARAM = {
	"TurnRate",
	"MaxTurnRateAngle",
	"SensorSize",
	"CollisionPenalty",
	"DodgingPenalty",
	"PenetrationPenalty",
	"SidednessChangingPenalty",
	"VelocityHysteresis"
};

array<float> STEERING_DEFAULTS = {
	220.0,
	35.0,
	300.0,
	3.0,
	0.7,
	0.0,
	1.0,
	0.1
};

const int MAX_MELEE_BUNDLES = 5;

void MeleeBundleRemoveButtonClicked(asset Asset, const string& ID)
{
	if (MessageBox("Are you sure you want to remove Melee Bundle " + ( ID.ToInt() + 1 ) + "?", "YESNO") == "NO")
		return;

	for (int i = ID.ToInt(); i < MAX_MELEE_BUNDLES; i++)
	{
		Asset.GetEntryVariable( "aivsaiMeleeBundle" + i ).SetValue(Asset.GetEntryValue( "aivsaiMeleeBundle" + (i + 1) ));
	}
}

void GenerateUI( asset Asset )
{
	string assetName = Asset.GetName(); 
	assetName.MakeLower();
	
	// Archetype
	int isArchetypeAsset = assetName.Find("archetype", 0);
	bool isArchetypeAssetBool;
	if( isArchetypeAsset == -1 )
		isArchetypeAssetBool = false;
	else
		isArchetypeAssetBool = true;
	
	// Variant/Spawner
	int isVariantAsset = assetName.Find("variant", 0);
	
	bool isVariantAssetBool = false;
	if( isVariantAsset != -1 )
		isVariantAssetBool = true;	
				
	Asset.BeginCategory( "Archetype Attributes", ARCH_R, ARCH_G, ARCH_B, "archetype.png" );
	{
		Asset.AddEntry_Label( "archetypeInfo", "Archetype level attributes are inherited and cannot be overridden by variants or spawners, \nreserved for high level attributes tied to assets, code, and animation.\n" ).SetTitle( " " );
	
		Asset.AddEntry_Combo( "archetype", "none | human_clone | human_riotshield | human_rpg | robot | warlord | zombie | zombie_dog | skeleton | direwolf | civilian | zod_companion | margwa | mechz | mannequin | thrasher | raz | zombie_quad | keeper_companion | apothicon_fury | keeper | monkey | astronaut" ).SetTitle( "Archetype" ).Enable( isArchetypeAssetBool ).SetToolTip( "Available in script as self.archetype" );

		Asset.AddEntry_Combo( "type", "human | dog | robot | zombie | zombie_dog" ).SetTitle( "Species" ).Enable( isArchetypeAssetBool );
		
		Asset.AddEntry_Path( "csvInclude", "" ).SetRelativePath( "share/zone_source/" ).SetTitle( "ZPKG/CSV Include" ).SetToolTip( "Any additional assets that this vehicle type might need" ).Enable( isArchetypeAssetBool );

		Asset.BeginCategory( "Archetype Attributes" + ".Behavior and ASM Assets", ARCH_R, ARCH_G, ARCH_B, "archetype.png" );
		{
			Asset.AddEntry_Path( "behaviorTreeName", "" ).SetRelativePath( "share/raw/behavior/" ).SetTitle( "Behavior Tree" ).SetToolTip( "Behavior tree for this AI." ).Enable( isArchetypeAssetBool );
			Asset.AddEntry_Path( "animStateMachineName", "" ).SetRelativePath( "share/raw/animstatemachines/" ).SetTitle( "Animation State Machine" ).SetToolTip( "Animation state machine for this AI." ).Enable( isArchetypeAssetBool );
			Asset.AddEntry_Path( "animSelectorTableName", "" ).SetRelativePath( "share/raw/animtables/" ).SetTitle( "Animation Selector Table" ).SetToolTip( "Animation Selector Table for this AI." ).Enable( isArchetypeAssetBool );
			Asset.AddEntry_AssetCombo( "aimTable", "aimtable" ).SetToolTip("AI will use this aim table to determine aim extents.").SetTitle( "Aim Table" ).Enable( isArchetypeAssetBool );
		}

		Asset.BeginCategory( "Archetype Attributes" + ".Melee Bundles", ARCH_R, ARCH_G, ARCH_B, "archetype.png" );
		{
			Asset.AddEntry_AssetCombo( "assassinationBundle", "aiassassination" ).SetTitle( "Assassination Bundle" ).SetToolTip( "Use this script bundle when this AI gets assassinated." ).Enable( isArchetypeAssetBool );
			for ( int i = 0; i < MAX_MELEE_BUNDLES; i++ )
			{
				bool show = i == 0 || Asset.GetEntryValue( "aivsaiMeleeBundle" + (i-1) ) != "";
								
				Asset.AddEntry_AssetCombo( "aivsaiMeleeBundle" + i, "aiassassination" ).SetTitle( "AI vs AI Melee Bundle " + ( i + 1 ) ).SetToolTip( "Use this script bundle when this AI gets sync meleed." ).Enable( isArchetypeAssetBool ).Show( show ).UpdateOnChange(true);
				if (show)
					Asset.AddEntry_ButtonGroup("buttonGroup" + i).SetTitle("Edit").AddButton("Remove", "", "void MeleeBundleRemoveButtonClicked(asset Asset, const string& ID)", "" + i);
			}
		}
		
		Asset.BeginCategory( "Archetype Attributes" + ".FX Bundles", ARCH_R, ARCH_G, ARCH_B, "Icon_FX.png" );
		{
			Asset.AddEntry_AssetCombo( "aiFxBundle", "aifxtable").SetTitle("AI FX Bundle" ).Enable( isArchetypeAssetBool );
		}
		
		Asset.BeginCategory( "Archetype Attributes" + ".Size", ARCH_R, ARCH_G, ARCH_B, "archetype.png" );
		{
			Asset.AddEntry_Float( "physRadius", 15.0, 15.0, 100.0 ).SetTitle( "Physics Radius" ).SetToolTip( "Actor Physics radius." ).Enable( isArchetypeAssetBool );
			Asset.AddEntry_Float( "physHeight", 72.0, 15.0, 100.0 ).SetTitle( "Physics Height" ).SetToolTip( "Actor Physics height." ).Enable( isArchetypeAssetBool );
		}
						
		Asset.BeginCategory( "Archetype Attributes" + ".Behaviors", ARCH_R, ARCH_G, ARCH_B, "archetype.png" );
		{	
			Asset.AddEntry_CheckBox( "usesCovernodes", true ).SetTitle( "Cover Behavior" ).SetToolTip( "When set to true, AI will display cover behavior when at cover node, otherwise it will act as standing exposed." ).Enable( isArchetypeAssetBool );
			Asset.AddEntry_CheckBox( "ignoresDamageHitLocations", false ).SetTitle( "Ignore Damage Hit Locations" ).Enable( isArchetypeAssetBool );
			Asset.AddEntry_CheckBox( "ignoreVortex", false ).SetTitle( "Ignore Vortex" ).Enable( isArchetypeAssetBool );
		}
		
		Asset.BeginCategory( "Archetype Attributes" + ".Cover", ARCH_R, ARCH_G, ARCH_B, "archetype.png" );
		{
			bool overrideCover = Asset.AddEntry_CheckBox( "overrideCover", false ).Show( false ).GetBool();
			string overrideText = ( overrideCover ) ? "Clear Cover Overrides" : "Add Cover Overrides";
			
			Asset.AddEntry_Label( "overrideInfo", "Specify archetype specific node offsets etc." ).SetTitle( " " ).Enable( isArchetypeAssetBool );
			Asset.AddEntry_ButtonGroup( "overrideCoverButton" ).SetTitle( "\n\n" ).AddButton( overrideText, "", "void OverrideCover( asset Asset, const string& param )", "" ).Enable( isArchetypeAssetBool );
		
			if ( overrideCover )
			{
				Asset.AddEntry_Label( "coverPositionOffsetInfo", "The \"x\" and \"y\" inches to offset what the archetype considers to be the nodes origin." ).SetTitle( "Position Offset <small>(x, y)</small>" ).Enable( isArchetypeAssetBool );
				Asset.AddEntry_Label( "coverPositionOffsetInfo2", "    ex: \"x\" = -10, will cause the archetype to treat 10 inches to the left of the node as the origin." ).SetTitle( " " ).Enable( isArchetypeAssetBool );
				Asset.AddEntry_Label( "coverPositionOffsetInfo3", "    ex: \"y\" = -10, will cause the archetype to treat 10 inches behind the node as the origin." ).SetTitle( " " ).Enable( isArchetypeAssetBool );
				Asset.AddEntry_Label( "coverRotationOffsetInfo", "The number of degrees to rotate the node's forward vector by counter clockwise.  A rotation " ).SetTitle( "Rotation Offset <small>(yaw)</small>" ).Enable( isArchetypeAssetBool );
				Asset.AddEntry_Label( "coverRotationOffsetInfo2", "offset is applied after the position offset in calculations." ).SetTitle( " " ).Enable( isArchetypeAssetBool );
				Asset.AddEntry_Label( "coverRotationOffsetInfo3", "    ex: \"yaw\" = 180, will flip the node's forward direction to the archetype." ).SetTitle( " " ).Enable( isArchetypeAssetBool );
			}
		
			for ( int index = 0; index < COVERS.length(); index++ )
			{
				Asset.BeginCategory( "Archetype Attributes" + ".Cover" + ".Cover " + COVERS[index], ARCH_R, ARCH_G, ARCH_B, "" );
				{
					const string xName = "cover" + COVERS[index] + "PosOffsetX";
					const string yName = "cover" + COVERS[index] + "PosOffsetY";
					const string rotName = "cover" + COVERS[index] + "RotOffset";
					
					Asset.AddEntry_Vector2( xName, yName, 0, 0, -15, 15 ).SetStep( 1 ).SetTitle( "Position Offset <small>(x,y)</small>" ).SetToolTip( "" ).Enable( isArchetypeAssetBool ).Show( overrideCover ).Enable( isArchetypeAssetBool );
					entryControl@ rotation = Asset.AddEntry_Float( rotName, 0, -180, 180 ).SetStep( 0.5 ).SetTitle( "Rotation Offset <small>(yaw)</small>" ).SetToolTip( "" ).Enable( isArchetypeAssetBool ).Show( overrideCover ).Enable( isArchetypeAssetBool );
					
					if ( !overrideCover )
					{
						Asset.GetEntryVariable( xName ).SetInt( 0 );
						Asset.GetEntryVariable( yName ).SetInt( 0 );
						rotation.SetFloat( 0 );
					}
				}
			}
		}
		
		Asset.BeginCategory( "Archetype Attributes" + ".Steering", ARCH_R, ARCH_G, ARCH_B, "archetype.png" );
		{
			array<bool> overrideSteering;
			bool hasOverrideSteering = false;
			
			Asset.AddEntry_Label( "steeringInfo", "Attributes which control how AI's move around the environment and interact with other AI's." ).SetTitle( " " );
			
			for ( int index = 0; index < STEERING.length(); index++ )
			{
				string prefix = STEERING[index];
				
				overrideSteering.insertLast( Asset.AddEntry_CheckBox( "override" + prefix + "Steering", false ).Show( false ).GetBool() );
				string overrideText = ( overrideSteering[index] ) ? "Clear " + prefix + " Customization" : "Customize " + prefix + " Steering";
				
				hasOverrideSteering = hasOverrideSteering || overrideSteering[index];
				
				Asset.AddEntry_ButtonGroup( "overrideSteeringButton" ).SetTitle( "\n\n" ).AddButton( overrideText, "", "void OverrideSteering( asset Asset, const string& param )", prefix ).Enable( isArchetypeAssetBool );
			}
			
			if ( hasOverrideSteering )
			{
				Asset.AddEntry_Label( "steeringMaxTurnRateInfo1", "Degrees per second that code will change an AI's orientation." ).SetTitle( "Turn Rate <small>(degrees / sec)</small>" );
				Asset.AddEntry_Label( "steeringMaxTurnRateInfo2", "Lower values will smooth movement, but can make AI unable to take sharp turns." ).SetTitle( " " );
				Asset.AddEntry_Label( "steeringMaxTurnAngleInfo1", "Maximum motion angle that AI's will apply their 'Turn Rate' when moving along their path." ).SetTitle( "Max Turn Rate Angle <small>(degrees)</small>" );
				Asset.AddEntry_Label( "steeringMaxTurnAngleInfo2", "Higher values allow AI's to smoothly follow their path, but can allow the AI to hit walls.").SetTitle( " " );
				Asset.AddEntry_Label( "steeringSensorSizeInfo1", "Character's sensor volume size.  Higher values increase the distance objects will be" ).SetTitle( "Sensor Size <small>(inches)</small>" );
				Asset.AddEntry_Label( "steeringSensorSizeInfo2", "considered for avoidance." ).SetTitle( " " );
				Asset.AddEntry_Label( "steeringCollisionPenaltyInfo1", "Higher values will cause AI's to react earlier, but become unable to push through crowds." ).SetTitle( "Collision Penalty Multiplier" );
				Asset.AddEntry_Label( "steeringDodgingPenaltyInfo1", "Higher values cause AI's to avoid collisions by speeding up or slowing down; lower values" ).SetTitle( "Dodging Penalty Multiplier" );
				Asset.AddEntry_Label( "steeringDodgingPenaltyInfo2", "cause AI's to turn to avoid collisions." ).SetTitle( " " );
				Asset.AddEntry_Label( "steeringPenetrationPenaltyInfo1", "Higher values will cause AI's to veer off quickly when colliding; lower values can result in" ).SetTitle( "Penetration Penalty Multiplier" );
				Asset.AddEntry_Label( "steeringPenetrationPenaltyInfo2", "smoother locomotion." ).SetTitle( " " );
				Asset.AddEntry_Label( "steeringSidednessPenaltyInfo1", "Higher values can resolve reciprocal oscillations but cause AI's to wander far from their" ).SetTitle( "Sidedness Penalty Multiplier" );
				Asset.AddEntry_Label( "steeringSidednessPenaltyInfo2", "desired trajectory." ).SetTitle( " " );
				Asset.AddEntry_Label( "steeringVelocityHysteresisInfo1", "Higher values can prevent velocity twitches but cause AI's to follow inefficient trajectories." ).SetTitle( "Velocity Hysteresis Multiplier" );
			}
			
			for ( int index = 0; index < STEERING.length(); index++ )
			{
				string prefix = STEERING[index];
				
				if ( overrideSteering[index] )
				{
					Asset.BeginCategory( "Archetype Attributes.Steering." + prefix + " Steering", ARCH_R, ARCH_G, ARCH_B, "");
					{
						int param = 0;
					
						Asset.AddEntry_Float( "steering" + prefix + STEERING_PARAM[param], STEERING_DEFAULTS[param], 0.0, 360.0 ).SetStep( 0.5 ).SetTitle( "Turn Rate <small>(degrees / sec)</small>" ).Enable( isArchetypeAssetBool );
						param++;
						Asset.AddEntry_Float( "steering" + prefix + STEERING_PARAM[param], STEERING_DEFAULTS[param], 0.0, 180.0 ).SetStep( 0.5 ).SetTitle( "Max Turn Rate Angle <small>(degrees)</small>" ).Enable( isArchetypeAssetBool );
						param++;
						Asset.AddEntry_Float( "steering" + prefix + STEERING_PARAM[param], STEERING_DEFAULTS[param], 0.0, 1000.0 ).SetStep( 0.5 ).SetTitle( "Sensor Size <small>(inches)</small>" ).Enable( isArchetypeAssetBool );
						param++;
						Asset.AddEntry_Float( "steering" + prefix + STEERING_PARAM[param], STEERING_DEFAULTS[param], 0.0, 30.0 ).SetStep( 0.5 ).SetTitle( "Collision Penalty Multiplier" ).Enable( isArchetypeAssetBool );
						param++;
						Asset.AddEntry_Float( "steering" + prefix + STEERING_PARAM[param], STEERING_DEFAULTS[param], 0.0, 1.0 ).SetStep( 0.1 ).SetTitle( "Dodging Penalty Multiplier" ).Enable( isArchetypeAssetBool );
						param++;
						Asset.AddEntry_Float( "steering" + prefix + STEERING_PARAM[param], STEERING_DEFAULTS[param], 0.0, 1000.0 ).SetStep( 0.5 ).SetTitle( "Penetration Penalty Multiplier" ).Enable( isArchetypeAssetBool );
						param++;
						Asset.AddEntry_Float( "steering" + prefix + STEERING_PARAM[param], STEERING_DEFAULTS[param], 0.0, 5.0 ).SetStep( 0.01 ).SetTitle( "Sidedness Penalty Multiplier" ).Enable( isArchetypeAssetBool );
						param++;
						Asset.AddEntry_Float( "steering" + prefix + STEERING_PARAM[param], STEERING_DEFAULTS[param], 0.0, 5.0 ).SetStep( 0.01 ).SetTitle( "Velocity Hysteresis Multiplier" ).Enable( isArchetypeAssetBool );
					}
				}
			}
		}

		Asset.BeginCategory( "Archetype Attributes" + ".Content Settings", ARCH_R, ARCH_G, ARCH_B, "archetype.png" );
		
		Asset.AddEntry_Label( "matureGibInfo", "When checked, gibbing will not happen if mature content is disabled." ).SetTitle( " " );
		Asset.AddEntry_CheckBox( "matureGib", false ).SetTitle( "Mature Gib" ).SetToolTip( "" ).Enable( isArchetypeAssetBool );
		
		Asset.AddEntry_Label( "restrictedGibInfo", "When checked, gibbing will not happen on gib restricted localizations." ).SetTitle( " " );
		Asset.AddEntry_CheckBox( "restrictedGib", true ).SetTitle( "Restricted Gib" ).SetToolTip( "" ).Enable( isArchetypeAssetBool );
		
		Asset.AddEntry_Label( "proceduralTraversalsInfo", "When checked, AI will path across procedural traversals.  The AI's behavior tree must\nhandle actually taking the procedural traversal." ).SetTitle( " " );
		Asset.AddEntry_CheckBox( "proceduralTraversals", false ).SetTitle( "Procedural Traversals" ).SetToolTip( "" ).Enable( isArchetypeAssetBool );
	}

	// Variant
	Asset.BeginCategory( "Variant Attributes", VAR_R, VAR_G, VAR_B, "variant.png"  );
	{
		Asset.AddEntry_Label( "variantInfo", "Variant level attributes are inherited and cannot be overridden by spawners, \ntypically reserved for large variations of the same base AI type.\n" ).SetTitle( " " );
	
		Asset.BeginCategory( "Variant Attributes" + ".Animation Maps", VAR_R, VAR_G, VAR_B, "variant.png" );
		{
			Asset.AddEntry_Label( "animMappingTableDefaultInfo", "Initial Animation Mapping Table the AI will select animations from." ).SetTitle( " " );
			Asset.AddEntry_Combo( "animMappingTableDefault", "table1 | table2 | table3" ).SetTitle( "Default Anim Mapping Table" ).Enable( isArchetypeAssetBool || isVariantAssetBool );
		
			Asset.AddEntry_Path( "animMappingTableName", "" ).SetRelativePath( "share/raw/animtables/" ).SetTitle( "Animation Mapping Table 1" ).SetToolTip( "Animation Mapping Table for this AI." ).Enable( isArchetypeAssetBool || isVariantAssetBool );
			Asset.AddEntry_Path( "animMappingTableName2", "" ).SetRelativePath( "share/raw/animtables/" ).SetTitle( "Animation Mapping Table 2" ).SetToolTip( "Second Animation Mapping Table for this AI." ).Enable( isArchetypeAssetBool || isVariantAssetBool );
			Asset.AddEntry_Path( "animMappingTableName3", "" ).SetRelativePath( "share/raw/animtables/" ).SetTitle( "Animation Mapping Table 3" ).SetToolTip( "Third Animation Mapping Table for this AI." ).Enable( isArchetypeAssetBool || isVariantAssetBool );
		}

		Asset.BeginCategory( "Variant Attributes" + ".Definitions", VAR_R, VAR_G, VAR_B, "variant.png" );
		{
			Asset.AddEntry_Label( "variantShootAtTagInfo", "Tag other AI's should shoot at to hit this AI, defaults to \"tag_eye\"." ).SetTitle( " " );
			Asset.AddEntry_BoneCombo( "shootAtTag", "radiantModel" ).SetTitle( "Shoot at Tag" ).SetToolTip( "" ).Enable( isArchetypeAssetBool || isVariantAssetBool );
			
			Asset.AddEntry_Label( "variantAimAtTagInfo", "Tag the player will aim at when ADS'ing, defaults to \"j_spine4\"." ).SetTitle( " " );
			Asset.AddEntry_BoneCombo( "aimAtTag", "radiantModel" ).SetTitle( "Aim at Tag" ).SetToolTip( "" ).Enable( isArchetypeAssetBool || isVariantAssetBool );
			
			Asset.AddEntry_Label( "variantHeroInfo", "Flags the AI as a hero, exposed to code/script for specialized logic." ).SetTitle( " " );
			Asset.AddEntry_CheckBox( "hero", false ).SetTitle( "Hero" ).SetToolTip( "" ).Enable( isArchetypeAssetBool || isVariantAssetBool );
			
			Asset.AddEntry_Label( "allowFriendlyFireInfo", "Allow the player to shoot this AI even if they are on team \"allies\" or \"neutral\"." ).SetTitle( " " );
			Asset.AddEntry_CheckBox( "allowFriendlyFire", false ).SetTitle( "Allow Friendly Fire" ).SetToolTip( "" ).Enable( isArchetypeAssetBool || isVariantAssetBool );
		}
		
		Asset.BeginCategory( "Variant Attributes" + ".Team" , VAR_R, VAR_G, VAR_B, "variant.png" );
		{
			Asset.AddEntry_Combo( "team", "axis | allies | team3 | neutral" ).SetTitle( "Team" ).Enable( isArchetypeAssetBool || isVariantAssetBool );
		}
		
		Asset.BeginCategory( "Variant Attributes" + ".Tunables", VAR_R, VAR_G, VAR_B, "variant.png" );
		{
			Asset.AddEntry_Label( "tunableInfo", "" ).SetTitle( " " );
			
			Asset.BeginCategory( "Variant Attributes" + ".Tunables" + ".Awareness Attributes", VAR_R, VAR_G, VAR_B, "" );
			{
				Asset.AddEntry_Int( "sightDistance", 8192, 256, 8192 ).SetTitle( "Sight Awareness Radius" ).SetToolTip( "Sight distance" ).Enable( isArchetypeAssetBool || isVariantAssetBool );
			}

			Asset.BeginCategory( "Variant Attributes" + ".Tunables" + ".Engagement Distances", VAR_R, VAR_G, VAR_B, "" );
			{
				Asset.AddEntry_Float( "engageMinDist", 256.0, 0.0, 4096.0 ).SetStep( 0.001 ).SetTitle( "Min Distance" );
				Asset.AddEntry_Float( "engageMinFalloffDist", 0.0, 0.0, 4096.0 ).SetStep( 0.001 ).SetTitle( "Min Falloff Distance" );
				Asset.AddEntry_Float( "engageMaxDist", 768.0, 0.0, 4096.0f ).SetStep( 0.001 ).SetTitle( "Max Distance" );
				Asset.AddEntry_Float( "engageMaxFalloffDist", 1024.0, 0.0, 4096.0 ).SetStep( 0.001 ).SetTitle( "Max Falloff Distance" );    		
			}
			
			Asset.BeginCategory( "Variant Attributes" + ".Tunables" + ".Tactical Walk Quadrants", VAR_R, VAR_G, VAR_B, "" );
			{
				Asset.AddEntry_Float( "frontQuadrantDegrees", 90.0, 0.0, 360.0 ).SetStep( 0.1 ).SetTitle( "Forward Degrees" );
				Asset.AddEntry_Float( "backQuadrantDegrees", 90.0, 0.0, 360.0 ).SetStep( 0.1 ).SetTitle( "Backward Degrees" );
				Asset.AddEntry_Float( "leftQuadrantDegrees", 90.0, 0.0, 360.0 ).SetStep( 0.1 ).SetTitle( "Left Degrees" );
				Asset.AddEntry_Float( "rightQuadrantDegrees", 90.0, 0.0, 360.0 ).SetStep( 0.1 ).SetTitle( "Right Degrees" );
			}
			
			Asset.BeginCategory( "Variant Attributes" + ".Tunables" + ".Combat Attributes", VAR_R, VAR_G, VAR_B, "" );
			{
				Asset.AddEntry_Label( "pathEnemyFightDistInfo", "AI's will stop moving when their enemy is within this distance and turn to engage them." ).SetTitle( " " );
				Asset.AddEntry_Int( "pathEnemyFightDist", 192, 0, 512 ).SetTitle( "Path Enemy Fight Distance" ).SetToolTip( "" );
				Asset.AddEntry_Int( "runAndGunDist", 192, 1, 2000 ).SetTitle( "Run and Gun Distance" ).SetToolTip( "AI will sprint when it is not within this range from the enemy." );
				Asset.AddEntry_Int( "faceenemyfightdist", 512, 0, 5000 ).SetTitle( "Face Enemy Distance" ).SetToolTip( "At this distance from enemy, AI will face and shoot the enemy while moving towards its goal." );
				Asset.AddEntry_Int( "coversearchinterval", 2000, 2000, 10000 ).SetTitle( "Cover Search Interval" ).SetToolTip( "Interval between cover node evaluation. The bigger the interval, less reactive (or more static) the AI will become." );
				Asset.AddEntry_Label( "newthreatdelayInfo", "Delay between selecting a new enemy once the current enemy has been killed." ).SetTitle( " " );
				Asset.AddEntry_Int( "newthreatdelay", 500, 0, 10000 ).SetTitle( "New Threat Delay (ms)" ).SetToolTip( "" );
				
				Asset.AddEntry_Label( "newpaindelayInfo", "Delay between when the actor will react to another pain." ).SetTitle( " " );
				Asset.AddEntry_Int( "newpaindelay", 875, 0, 10000 ).SetTitle( "New Pain Delay (ms)" ).SetToolTip( "" );
			}
			
			Asset.BeginCategory( "Variant Attributes" + ".Tunables" + ".Shooting Attributes", VAR_R, VAR_G, VAR_B, "" );
			{
				Asset.AddEntry_Label( "shootanglethresholdInfo", "How many degrees the AI's bullet can deviate from where the weapon muzzle is pointing." ).SetTitle( " " );
				Asset.AddEntry_Int( "shootanglethreshold", 5, 0, 180 ).SetTitle( "Shoot Angle Threshold" ).SetToolTip( "" );
				
				Asset.AddEntry_Label( "closeshootangledistanceInfo", "Enemies closer than this distance will have the \"Close Shoot Angle Threshold\" applied." ).SetTitle( " " );
				Asset.AddEntry_Int( "closeshootangledistance", 120, 0, 2000 ).SetTitle( "Close Shoot Angle Distance" ).SetToolTip( "" );
				
				Asset.AddEntry_Label( "closeshootanglethresholdInfo", "How many degrees the AI's bullet can deviate from the muzzle at close range." ).SetTitle( " " );
				Asset.AddEntry_Int( "closeshootanglethreshold", 15, 0, 180 ).SetTitle( "Close Shoot Angle Threshold" ).SetToolTip( "" );
			}
			
            Asset.BeginCategory( "Variant Attributes" + ".Tunables" + ".Movement Attributes", VAR_R, VAR_G, VAR_B, "" );
			{
				Asset.AddEntry_CheckBox( "fixedNode", false ).SetTitle( "Fixed Node" ).SetToolTip( "When Set to true, AI will not evaluate cover nodes, no matter what the goal radius is. Use for keeping AI moving by themselves." ).Enable( isArchetypeAssetBool || isVariantAssetBool );				
				Asset.AddEntry_CheckBox( "pacifist", false ).SetTitle( "Pacifist" ).SetToolTip( "When Set to true, AI will not fire until fired upon." ).Enable( isArchetypeAssetBool || isVariantAssetBool );
				Asset.AddEntry_Int( "defaultGoalRadius", 2048, 16, 2048 ).SetToolTip( "Starting goal radius of AI." ).SetTitle( "Default Goalradius" ).Enable( isArchetypeAssetBool || isVariantAssetBool );
			}
            
			Asset.BeginCategory( "Variant Attributes" + ".Tunables" + ".Magic Bullet Shield Attributes", VAR_R, VAR_G, VAR_B, "" );
			{
				Asset.AddEntry_Int( "painTolerance", 0, 5000, 10000 ).SetToolTip( "Milliseconds before another pain can play on an actor with magic bullet shield." ).SetTitle( "Pain Tolerance" ).Enable( isArchetypeAssetBool || isVariantAssetBool );
			}
		}
		
		Asset.BeginCategory( "Variant Attributes" + ".Traversals", VAR_R, VAR_G, VAR_B, "variant.png");
		{
