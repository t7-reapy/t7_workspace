				Asset.AddEntry_Combo( "burstCountMin", "3 | 4 | 5 | 6" ).SetTitle( "Burst Count Min" ).SetToolTip( "AI will choose randomly between min and max burst count." ).Enable( isArchetypeAssetBool || isVariantAssetBool ).Show( Asset.GetEntryValue( "fireMode" ) == "burst" ? true : false );				
				Asset.AddEntry_Combo( "burstCountMax", "6 | 5 | 4 | 3" ).SetTitle( "Burst Count Max" ).SetToolTip( "AI will choose randomly between min and max burst count." ).Enable( isArchetypeAssetBool || isVariantAssetBool ).Show( Asset.GetEntryValue( "fireMode" ) == "burst" ? true : false );						
				
				Asset.AddEntry_Float( "fireIntervalmin", 0.1, 0.1, 10.0 ).SetStep( 0.1 ).SetTitle( "Fire Interval Min" ).SetToolTip( "Random interval (min) between two fire volleys." ).Enable( isArchetypeAssetBool || isVariantAssetBool ).Show( ( Asset.GetEntryValue( "fireMode" ) == "burst" || Asset.GetEntryValue( "fireMode" ) == "singleshot" ) ? true : false );
				Asset.AddEntry_Float( "fireIntervalmax", 0.1, 0.1, 10.0 ).SetStep( 0.1 ).SetTitle( "Fire Interval Max" ).SetToolTip( "Random interval (max) between two fire volleys." ).Enable( isArchetypeAssetBool || isVariantAssetBool ).Show( ( Asset.GetEntryValue( "fireMode" ) == "burst" || Asset.GetEntryValue( "fireMode" ) == "singleshot" ) ? true : false );						
			}
		}
