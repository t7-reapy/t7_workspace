void OverrideCover( asset Asset, const string& param )
{
	entryControl@ overrideCover = Asset.GetEntryVariable( "overrideCover" );
	
	if ( overrideCover.GetBool() )
	{
		if ( MessageBox( "Are you sure you want to clear cover overrides?", "YESNO" ) == "YES" )
		{
			overrideCover.SetBool( !overrideCover.GetBool() );
		}
	}
	else
	{
		overrideCover.SetBool( !overrideCover.GetBool() );
	}
}

void OverrideSteering( asset Asset, const string& param )
{
	entryControl@ overrideSteering = Asset.GetEntryVariable( "override" + param + "Steering" );
	
	if ( overrideSteering.GetBool() )
	{
		if ( MessageBox( "Are you sure you want to clear " + param + " Steering Customizations?", "YESNO" ) == "YES" )
		{
			overrideSteering.SetBool( !overrideSteering.GetBool() );
			
			for ( int index = 0; index < STEERING_PARAM.length(); index++)
			{
				Asset.GetEntryControl( "steering" + param + STEERING_PARAM[index] ).SetFloat( STEERING_DEFAULTS[index] );
			}
		}
	}
	else
	{
		overrideSteering.SetBool( !overrideSteering.GetBool() );
	}
}