			Asset.AddEntry_Float( "nitrous_jump_force_in_air", 0, 0, 2000 ).SetStep( 1 ).SetTitle( "Jump Force In Air" ).Show( isNitrous ).SetToolTip( "The amount of force applied when jumping while in air." );
			Asset.AddEntry_Float( "nitrous_jump_force_from_wall", 0, 0, 2000 ).SetStep( 1 ).SetTitle( "Jump Force From Wall" ).Show( isNitrous ).SetToolTip( "The amount of force applied when jumping from a wall.  Bind moveUpButton to enable. Drive On Walls also needs to be checked. Only used if non-zero." );
