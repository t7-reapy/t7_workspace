			Asset.AddEntry_Float( "nitrous_jump_force_from_wall_extra_z", 0, 0, 2000 ).SetStep( 1 ).SetTitle( "Jump Force From Wall Extra Z" ).Show( isNitrous ).SetToolTip( "When jumping from a wall, the extra world z force to apply." );
			Asset.AddEntry_Float( "nitrous_jump_gravity_scale_upwards", 1, 0.01, 100 ).SetStep( 0.1 ).SetTitle( "Jump Gravity Scale Upwards" ).Show( isNitrous ).SetToolTip( "The extra gravity scale when jumping upwards with button pressed." );
			Asset.AddEntry_Float( "nitrous_jump_gravity_scale_transition_z", 0, -8000, 8000 ).SetStep( 5 ).SetTitle( "Jump Gravity Scale Transition Z" ).Show( isNitrous ).SetToolTip( "The delta z used to transition from upwards to downwards while jump buttons is pressed." );
			Asset.AddEntry_Float( "nitrous_jump_gravity_scale_downwards", 1, 0.01, 100 ).SetStep( 0.1 ).SetTitle( "Jump Gravity Scale Downwards" ).Show( isNitrous ).SetToolTip( "The extra gravity scale when falling downwards during a jump with button pressed." );
			Asset.AddEntry_Float( "nitrous_jump_from_wall_stick_angle", 0, 0, 180 ).SetStep( 1 ).SetTitle( "Jump From Wall Stick Angle" ).Show( isNitrous ).SetToolTip( "The angle needed to jump off wall between the stick deflection face angle needed to be within the wall normal. Ignored if zero." );
			Asset.AddEntry_CheckBox( "nitrous_jumps_require_button_release", false ).SetTitle( "Jump Requires Button Release" ).SetToolTip( "If unchecked, when the moveUpButton is held down, the vehicle automatically rejumps." );
