			Asset.AddEntry_Float( "nitrous_tire_fric_assist_threshold", 1.5, 0.1, 100000 ).SetStep( 0.01 ).Show( isNitrous ).SetTitle( "Friction Assist Threshold" );			
			Asset.AddEntry_Float( "nitrous_tire_fric_load_factor_min", 0.85, 0, 10 ).Show( isNitrous ).SetTitle( "Scale Spring Uncompressed" );									
			Asset.AddEntry_Float( "nitrous_tire_fric_load_factor_max", 1.7, 0, 10 ).Show( isNitrous ).SetTitle( "Scale Spring Compressed" );			
			Asset.AddEntry_Vector3( "nitrous_wheel_offset_x", "nitrous_wheel_offset_y", "nitrous_wheel_offset_z", 0, 0, 0, -1000, 1000 ).SetStep( 5 ).Show( isNitrous ).SetTitle( "Wheel Constraint Offset" );
		}	

		Asset.BeginCategory( "Physics Vehicle Parameters.Suspension" );
