			Asset.AddEntry_Vector3( "nitrous_bbox_max_x", "nitrous_bbox_max_y", "nitrous_bbox_max_z", 0, 0, 0, -100000, 100000 ).Show( isNitrous ).SetStep( 5 ).SetTitle( "BBox Max" ).SetToolTip( "Max dimension of the inertia box" );
