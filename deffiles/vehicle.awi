		Asset.AddEntry_String( "deathFxSound", "" ).SetTitle( "Sound" );
	}
	
	// LightFx
	
  const int MAX_NUM_LIGHTFX = 4;
	Asset.BeginCategory( "LightFx", 1, 0.3, 0.2, "Icon_FX.png" );		
	{
    Asset.AddEntry_Int( "lightFx_numslots", 4, 0, MAX_NUM_LIGHTFX ).SetTitle( "Number of Slots" ).UpdateOnChange(true);
    int numSlots = Asset.GetEntryInt( "lightFx_numslots" );

    for ( int i = 1; i <= MAX_NUM_LIGHTFX; i++ )
    {
        bool isValid = (i <= numSlots);
        Asset.AddEntry_Path( "lightFxName" + i, "" ).SetTitle( "Light " + i + " Fx" ).SetRelativePath( "share/raw/fx/" ).Show(isValid).SetSave(isValid);
        Asset.AddEntry_BoneCombo( "lightFxTag" + i, modelsList ).SetTitle( "Light " + i + " Tag" ).Show(isValid).SetSave(isValid);
    }
	}

	// ExhaustFx
	Asset.BeginCategory( "ExhaustFx", 1, 0.3, 0.2, "Icon_FX.png" );	
	{
		Asset.AddEntry_Path( "exhaustFx", "" ).SetTitle( "Name" ).SetRelativePath( "share/raw/fx/" ).SetToolTip( "First fx plays on tag_engine_left, then tag_engine_right" );
		Asset.AddEntry_BoneCombo( "exhaustFxTag1", modelsList ).SetTitle( "Exhaust Tag1" ).SetToolTip( "Play the exhaust on this tag" );
		Asset.AddEntry_BoneCombo( "exhaustFxTag2", modelsList ).SetTitle( "Exhaust Tag2" ).SetToolTip( "Optional additional exhaust tag" );
	}
		
