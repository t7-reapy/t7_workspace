	}
	
	// -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -
		
		Asset.BeginCategory( "Boost Parameters" );
		{
			Asset.AddEntry_Int( "boostAccelMultiplier", 0, 0, 100 ).SetTitle( "Boost Accel Multiplier" ).SetStep( 1 ).SetToolTip( "When boosting, the increase in acceleration the vehicle will get" );
			Asset.AddEntry_Float( "boostSpeedIncrease", 0, 0, 100 ).SetTitle( "Boost Speed Increase" ).SetStep( 0.5 ).SetToolTip( "When boosting, the increase in speed the vehicle recieves, multiplier on the base max speed" );
			Asset.AddEntry_Float( "boostDuration", 0, 0, 1000 ).SetTitle( "Boost Duration" ).SetStep( 1 ).SetToolTip( "Duration in seconds that the boost will last." );
			Asset.AddEntry_Float( "boostDurationMin", 0, 0, 1000 ).SetTitle( "Boost Duration Minimum" ).SetStep( 1 ).SetToolTip( "Minimum boost duration required to initiate boost." );
			Asset.AddEntry_Float( "boostRecoveryScalar", 1.0, 0, 10 ).SetTitle( "Boost Recovery Scalar" ).SetStep( 0.1 ).SetToolTip( "Scales boost recovery time, so 0.5 results in recovery taking twice as long as boostDuration." );
		}
		

