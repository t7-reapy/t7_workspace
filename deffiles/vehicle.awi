		string ButtonItemsA = "BUTTON_LTRIG | BUTTON_RTRIG | BUTTON_RSHLDR | BUTTON_LSHLDR | BUTTON_A | BUTTON_B | BUTTON_X | BUTTON_Y | none";
		string ButtonItemsB = "BUTTON_RTRIG | BUTTON_LTRIG | BUTTON_RSHLDR | BUTTON_LSHLDR | BUTTON_A | BUTTON_B | BUTTON_X | BUTTON_Y | BUTTON_LSTICK | BUTTON_RSTICK | none";
		string ButtonItemsC = "none | BUTTON_Y | BUTTON_RSHLDR | BUTTON_LTRIG | BUTTON_RTRIG | BUTTON_LSHLDR | BUTTON_A | BUTTON_B | BUTTON_X | BUTTON_LSTICK | BUTTON_RSTICK";
		string ButtonItemsD = "none | BUTTON_B | BUTTON_LTRIG | BUTTON_RTRIG | BUTTON_RSHLDR | BUTTON_LSHLDR | BUTTON_A | BUTTON_X | BUTTON_Y | BUTTON_LSTICK | BUTTON_RSTICK";
		string ButtonItemsE = "none | BUTTON_RSHLDR | BUTTON_LTRIG | BUTTON_RTRIG | BUTTON_LSHLDR | BUTTON_A | BUTTON_B | BUTTON_X | BUTTON_Y | BUTTON_LSTICK | BUTTON_RSTICK";
		string ButtonItemsF = "none | BUTTON_LSHLDR | BUTTON_LTRIG | BUTTON_RTRIG | BUTTON_RSHLDR | BUTTON_A | BUTTON_B | BUTTON_X | BUTTON_Y | BUTTON_LSTICK | BUTTON_RSTICK";
		
		string AxisItemsA = "AXIS_LSTICK | AXIS_RSTICK | none";		
		string AxisItemsB = "none | AXIS_LSTICK | AXIS_RSTICK";				
		
		Asset.AddEntry_Combo( "steerAxis", AxisItemsA ).Show( isDrivable );		
		Asset.AddEntry_Combo( "gasAxis", AxisItemsB ).Show( isDrivable );		
		Asset.AddEntry_Combo( "gasButton", ButtonItemsA ).Show( isDrivable );
		Asset.AddEntry_Combo( "reverseBrakeButton", ButtonItemsB ).Show( isDrivable );
		Asset.AddEntry_Combo( "handBrakeButton", ButtonItemsD ).Show( isDrivable );
		Asset.AddEntry_Combo( "attackButton", ButtonItemsB ).Show( isDrivable );
		Asset.AddEntry_Combo( "attackSecondaryButton", ButtonItemsB ).Show( isDrivable );
		Asset.AddEntry_Combo( "moveUpButton", ButtonItemsF ).Show( isDrivable );
		Asset.AddEntry_Combo( "moveDownButton", ButtonItemsE ).Show( isDrivable );
		Asset.AddEntry_Combo( "switchSeatButton", ButtonItemsB ).Show( isDrivable );
		Asset.AddEntry_Combo( "boostButton", ButtonItemsC ).Show( isDrivable );
		Asset.AddEntry_Path( "accelGraph", "" ).Show( isDrivable ).SetRelativePath( "share/raw/vehicle/" ).SetTitle( "Accel Graph" ).SetToolTip( "Graph file for in-game editing of the non-linear acceleration curve." );
		Asset.AddEntry_Path( "steerGraph", "" ).Show( isDrivable ).SetRelativePath( "share/raw/vehicle/" ).SetTitle( "Steering Graph" ).SetToolTip( "Graph file for in-game editing of the non-linear steering curve." );
		Asset.AddEntry_CheckBox( "noButtonAutoRemap", false ).Show( isDrivable ).SetToolTip( "Don't auto remap buttons based on users current controller config.  Used for zombietron game mode" );
	}
		
