	Asset.BeginCategory( "Jolt" );
	{
		Asset.AddEntry_CheckBox( "joltVehicle", false ).SetTitle( "Jolt Vehicle" ).SetToolTip( "Vehicle gets jolted.  Nitrous vehicle jolt when firing." );
		Asset.AddEntry_CheckBox( "joltVehicleDriver", true ).Show( !isNitrous ).SetTitle( "Jolt Vehicle Driver" ).SetToolTip( "Disables jolting for the vehicle driver." );
		Asset.AddEntry_Float( "joltMaxTime", 1.3, 0, 30 ).SetStep( 0.1 ).SetTitle( "Jolt Max Time" ).SetToolTip( "Time maximum vehicle jolt lasts." ).Show( !isNitrous );
		Asset.AddEntry_Float( "joltTime", 1.3, 0, 30 ).SetStep( 0.1 ).SetTitle( "Jolt Time" ).SetToolTip( "Time one vehicle jolt lasts." ).Show( !isNitrous );
		Asset.AddEntry_Float( "joltWaves", 2, 0, 360 ).SetStep( 0.1 ).SetTitle( "Jolt Waves" ).SetToolTip( "Jolt wave frequency. Zero means jump to max and ramp down" ).Show( !isNitrous );
		Asset.AddEntry_Float( "joltIntensity", 1, -50, 50 ).SetStep( 0.01 ).SetTitle(  "Jolt Intensity" ).SetToolTip( "Jolt Wave amplitude." );
	}
	
	Asset.BeginCategory( "Antennas" );
