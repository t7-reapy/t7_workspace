		// -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -	
		
		//Speed / Tilt / Brake
		
		Asset.BeginCategory( "Physics Vehicle Parameters.Boat Settings" );	
