			Asset.AddEntry_Float( "nitrous_hover_trace_length_from_wall", 100.0, 0, 5000 ).SetStep( 10.0 ).Show( isNitrous ).SetTitle( "Hover Trace Length From Wall" ).SetToolTip( "The trace length to find another wall when jumping off the wall." );
			Asset.AddEntry_Float( "nitrous_hover_to_wall_gravity_scale", 1.2, 0, 100 ).SetStep( 0.01 ).Show( isNitrous ).SetTitle( "Hover To Wall Gravity Scale" ).SetToolTip( "The gravity scale to use on hover vehicle when transitioning from ground to wall. Affects rate to attach to wall." );
			Asset.AddEntry_Float( "nitrous_hover_to_wall_upright_strength_multiplier", 20.0, 0.001, 200 ).SetStep( 0.1 ).Show( isNitrous ).SetTitle( "Hover To Wall Upright Strength Multiplier" ).SetToolTip( "The upright strength multiplier to use on hover vehicle when transitioning from ground to wall. Affects rate to rotate towards wall." );
			Asset.AddEntry_Float( "nitrous_hover_to_wall_gravity_lerp_rate", 10.0, 0, 100 ).SetStep( 0.01 ).Show( isNitrous ).SetTitle( "Hover To Wall Gravity LERP Rate" ).SetToolTip( "The rate to transition to wall gravity." );
			Asset.AddEntry_Float( "nitrous_hover_to_ground_gravity_lerp_rate", 10.0, 0, 100 ).SetStep( 0.01 ).Show( isNitrous ).SetTitle( "Hover To Ground Gravity LERP Rate" ).SetToolTip( "The rate to transition to ground gravity." );
			Asset.AddEntry_Float( "nitrous_hover_to_ground_upright_strength_multiplier", 3.5, 0.001, 200 ).SetStep( 0.1 ).Show( isNitrous ).SetTitle( "Hover To Ground Upright Strength Multiplier" ).SetToolTip( "The upright strength multiplier to use on hover vehicle when transitioning from wall to ground. Affects rate to rotate towards ground." );
