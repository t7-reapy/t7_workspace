	Asset.BeginCategory( "Collision" );
	{
		bool useCollmap = Asset.AddEntry_CheckBox( "useCollmap", false ).Show( !isNitrous ).SetTitle( "Use Collmap" ).UpdateOnChange( true ).GetBool();
		Asset.AddEntry_Float( "radius", 0, 0, 1000 ).SetStep( 0.01 ).SetTitle( "Collision cylinder radius" ).SetToolTip( "Collision the cylinder radius" );
		Asset.AddEntry_Float( "maxHeight", 0, -500, 500 ).SetStep( 0.01 ).SetTitle(  "Collision cylinder max height" ).SetToolTip( "Collision the cylinder max height" ).Show( !useCollmap && !isNitrous );
		Asset.AddEntry_Float( "minHeight", 0, -500, 500 ).SetStep( 0.01 ).SetTitle(  "Collision cylinder min height" ).SetToolTip( "Collision the cylinder min height" ).Show( !useCollmap && !isNitrous );
		
		Asset.AddEntry_Float( "lightCollisionSpeed", 0, 0, 10000 ).SetTitle( "Light Collision Speed" ).SetToolTip( "If the vehicle is moving faster than this speed in MPH it will play the rumble/camera shake and impact sounds" );
		Asset.AddEntry_AssetCombo( "lightCollisionRumble", "rumble" ).SetTitle( "Light Collision Rumble" );
		Asset.AddEntry_Float( "heavyCollisionSpeed", 15, 0, 10000 ).SetTitle( "Heavy Collision Speed" ).SetToolTip( "If the vehicle is moving faster than this speed in MPH it will play the rumble/camera shake" );
		Asset.AddEntry_AssetCombo( "heavyCollisionRumble", "rumble" ).SetTitle( "Heavy Collision Rumble" );
		Asset.AddEntry_AssetCombo( "jumpLandingRumble", "rumble" ).SetTitle( "Jump Landing Rumble" ).SetToolTip( "Play this rumble/camera shake when the vehicle lands on the ground" );
	}
	
