
void RotorFlapEntries( asset Asset, string boneEntry, int index, bool show )
{
	Asset.AddEntry_BoneCombo( boneEntry, "worldModel" ).SetTitle( "Flap Tag " + index ).Show( show );
	Asset.AddEntry_Combo( "rotorArmFlapType" + index, "PitchVelocity{0} | YawVelocity{1} | RollVelocity{2} | PitchYawVelLeft{3} | PitchYawVelRight{4}" ).Show( show ).SetTitle("Flap Type " + index );
	Asset.AddEntry_Float( "rotorArmFlapInf" + index, 1.0, -100.0, 100.0 ).Show( show ).SetToolTip( "+/- Influence percent" ).SetTitle( "Flap Scale " + index );	
}

void GenerateUI( asset Asset )
{
	// Unused
	
	Asset.AddEntry_String( "configstringFileType", "VEHICLEFILE" ).Show( false );
	
	// -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -

	string Type = Asset.AddEntry_Combo( "type", "4 wheel | motorcycle | tank | plane | boat | artillery | helicopter" ).SetTitle("Type").UpdateOnChange( true ).GetValue();
	Asset.AddEntry_String( "scriptVehicleType", "" ).SetTitle( "Script Vehicle Type" ).SetToolTip( "Field used in script so we don't have to check for every variant of a vehicle.  self.scriptVehicleType." );
	Asset.AddEntry_Combo( "archetype", "none | attack_drone | hunter | quadtank | scout | turret | wasp | amws | raps | siegebot | parasite | glaive | rcbomb | mothership | spider | sentinel_drone | dragon" ).SetTitle( "Archetype" ).SetToolTip( "Set this field if it is an Archetype." );
	Asset.AddEntry_Combo( "category", "None{0} | Quad Tank{1} | AMWS{2} | Wasp{3} | Rocket Wasp{4} | Hunter {5} | Siege Bot{6}" ).SetTitle( "Category" );
	Asset.AddEntry_String( "scoretype", "none" ).SetTitle( "Score Type" ).SetToolTip( "Should match the entries in the scoreevents table." );
	Asset.AddEntry_Combo( "team", "axis | allies | neutral | team3" ).SetTitle( "Team" );
	Asset.AddEntry_Path( "csvInclude", "" ).SetRelativePath( "share/zone_source/" ).SetTitle( "ZPKG Include" ).SetToolTip( "Any additional assets that this vehicle type might need" );
	//Asset.AddEntry_Path( "precacheScript", "" ).SetRelativePath( "share/raw/animscripts/aitype/" ).SetTitle( "Additional Precache Script" ).SetToolTip( "For precaching any additional items. Script must have a precache() function" );
	//Asset.AddEntry_Text( "comments", "" ).SetTitle( "Comments" );
	Asset.AddEntry_AssetCombo( "playerDrivenVersion" , "vehicle" ).SetTitle( "Player Driven Version" ).SetToolTip( "Spawner name for the version that the player will drive when he takes control of this vehicle.  If left blank, vehicle will not be swapped to another version." );
	Asset.AddEntry_CheckBox( "nonstick", false ).SetTitle( "Non-stick" ).SetToolTip( "Sticky weapons cannot stick to this vehicle if non-stick is enabled." );


	// -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -
	
	// Models
	
	Asset.BeginCategory( "Models" );
	{
		Asset.AddEntry_AssetCombo( "worldModel", "xmodel" ).SetTitle( "World Model" );
		Asset.AddEntry_AssetCombo( "viewModel", "xmodel" ).SetTitle( "View Model" ).SetToolTip( "Used for first person driver if set." );;
		Asset.AddEntry_AssetCombo( "deathModel", "xmodel" ).SetTitle( "Death Model" );
		Asset.AddEntry_AssetCombo( "enemyModel", "xmodel" ).SetTitle( "Enemy Model" ).SetToolTip( "If team is axis it will show this model if set" );
        Asset.AddEntry_AssetCombo( "destructibleDef", "destructibledef" ).SetTitle( "Destructible Def" );
		Asset.AddEntry_Float( "modelSwapDelay", 0, 0, 100000 ).SetStep( 0.01 ).SetTitle( "Swap Delay" );
		Asset.AddEntry_String( "driverHideTag1", "" ).SetTitle( "Driver Hide Part" ).SetToolTip( "Part on vehicle will be hidden for driver" );
		Asset.AddEntry_String( "driverOtherHideTag1", "" ).SetTitle( "Driver Other Hide Part 1" ).SetToolTip( "Part on vehicle will be hidden for driver" );
		Asset.AddEntry_String( "driverOtherHideTag2", "" ).SetTitle( "Driver Other Hide Part 2" ).SetToolTip( "Part on vehicle will be hidden for driver" );
		Asset.AddEntry_String( "driverOtherHideTag3", "" ).SetTitle( "Driver Other Hide Part 3" ).SetToolTip( "Part on vehicle will be hidden for driver" );
		Asset.AddEntry_String( "driverOtherHideTag4", "" ).SetTitle( "Driver Other Hide Part 4" ).SetToolTip( "Part on vehicle will be hidden for driver" );
	}
	
	// -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -

	// Wheels\Rotors
	bool isHeli = ( Type == "helicopter" );
	bool useHeliBoneControllers = isHeli;
	bool useHeliFlapRotors = false;
	
	Asset.BeginCategory( "Wheels" );	
	{
		Asset.AddEntry_Float( "texureScrollScale", 1, 0, 100 ).Show( !isHeli ).SetStep( 0.05 ).SetToolTip( "This is used to change the speed at which the tank treads scroll" );
		Asset.AddEntry_Float( "wheelRotRate", 0, 0, 100 ).Show( !isHeli ).SetStep( 0.05 ).SetToolTip( "How fast the wheels rotate, set to the wheel radius or set to 0 if playing an animation in script." );
		Asset.AddEntry_Float( "extraWheelRotScale", 1, 0, 10 ).Show( !isHeli ).SetStep( 0.05 ).SetToolTip( "How fast the extra wheels rotate relative to the normal wheelRotRate." );
		Asset.AddEntry_CheckBox( "wheelChildTakesSteerYaw", false ).Show( !isHeli ).SetToolTip( "If set, the wheel tag will only take the vertical movement and the child will take the yaw.  The child's children will take the spin." );
        Asset.AddEntry_CheckBox( "useHeliBoneControllers", false ).Show( !isHeli ).SetToolTip( "Use the air vehicle controllers instead of the ground controllers.  This is a trade for wheels moving up and down to rotors rotating" ).UpdateOnChange( true );
		useHeliBoneControllers = Asset.GetEntryBool( "useHeliBoneControllers" ) || isHeli;

		Asset.AddEntry_BoneCombo( "extraWheelLeft1", "worldModel" ).SetTitle( "Extra wheel tag 1" ).Show( !useHeliBoneControllers ).SetToolTip( "Use these bones for extra gears or wheels that also need to rotate" );
		Asset.AddEntry_BoneCombo( "extraWheelRight1", "worldModel" ).SetTitle( "Extra wheel tag 2" ).Show( !useHeliBoneControllers ).SetToolTip( "Use these bones for extra gears or wheels that also need to rotate" );
		Asset.AddEntry_BoneCombo( "extraWheelLeft2", "worldModel" ).SetTitle( "Extra wheel tag 3" ).Show( !useHeliBoneControllers ).SetToolTip( "Use these bones for extra gears or wheels that also need to rotate" );
		Asset.AddEntry_BoneCombo( "extraWheelRight2", "worldModel" ).SetTitle( "Extra wheel tag 4" ).Show( !useHeliBoneControllers ).SetToolTip( "Use these bones for extra gears or wheels that also need to rotate" );
	}

	

	// Compass	
	
	Asset.BeginCategory( "Compass" );	
	{
		Asset.AddEntry_CheckBox( "addToCompass", false ).SetTitle( "Show On Compass" );
		Asset.AddEntry_CheckBox( "addToCompassEnemy", false ).SetTitle( "Show On Enemy Compass" );
		Asset.AddEntry_CheckBox( "addToCompassEnemyFiring", false ).SetTitle( "Only Show On Enemy Compass While Firing" );
		Asset.AddEntry_AssetCombo( "compassIcon", "image" ).SetTitle( "Compass Icon" );
		Asset.AddEntry_BoneCombo( "compassIconTag", "worldModel" ).SetTitle( "Compass Icon Tag" );
		Asset.AddEntry_Float( "compassScale", 1, 0.1, 5 ).SetStep( 0.05 ).SetTitle( "Scale" ).SetToolTip( "How large to draw the minimap icon relative to others" ).Show( Type == "helicopter" );
	}
	
	// -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -

	// Attachments
	
	Asset.BeginCategory( "Attachments" );
	{
		Asset.AddEntry_AssetCombo( "mod0", "xmodel" ).SetTitle( "Model 1" );
		Asset.AddEntry_BoneCombo( "tag0", "worldModel" ).SetTitle( "Tag 1" );
		Asset.AddEntry_AssetCombo( "mod1", "xmodel" ).SetTitle( "Model 2" );
		Asset.AddEntry_BoneCombo( "tag1", "worldModel" ).SetTitle( "Tag 2" );
		Asset.AddEntry_AssetCombo( "mod2", "xmodel" ).SetTitle( "Model 3" );
		Asset.AddEntry_BoneCombo( "tag2", "worldModel" ).SetTitle( "Tag 3" );		
		Asset.AddEntry_AssetCombo( "mod3", "xmodel" ).SetTitle( "Model 4" );
		Asset.AddEntry_BoneCombo( "tag3", "worldModel" ).SetTitle( "Tag 4" );	
		
		Asset.AddEntry_AssetCombo( "dmod0", "xmodel" ).SetTitle( "Destroyed Model 1" );
		Asset.AddEntry_BoneCombo( "dtag0", "worldModel" ).SetTitle( "Tag 1" );
		Asset.AddEntry_AssetCombo( "dmod1", "xmodel" ).SetTitle( "Destroyed Model 2" );
		Asset.AddEntry_BoneCombo( "dtag1", "worldModel" ).SetTitle( "Tag 2" );
		Asset.AddEntry_AssetCombo( "dmod2", "xmodel" ).SetTitle( "Destroyed Model 3" );
		Asset.AddEntry_BoneCombo( "dtag2", "worldModel" ).SetTitle( "Tag 3" );
		Asset.AddEntry_AssetCombo( "dmod3", "xmodel" ).SetTitle( "Destroyed Model 4" );
		Asset.AddEntry_BoneCombo( "dtag3", "worldModel" ).SetTitle( "Tag 4" );	
	}
	
	Asset.BeginCategory( "Movement" );
	{
		Asset.AddEntry_Float( "minSpeed", 500, 0, 2000 ).SetStep( 0.05 ).SetTitle( "Min Speed" ).SetToolTip( "Min speed in MPH" ).Show( Type == "plane" );
		Asset.AddEntry_Float( "maxSpeed", 1100, 0, 2000 ).SetStep( 0.05 ).SetTitle( "Max Speed" ).SetToolTip( "Max speed in MPH" );
		Asset.AddEntry_Float( "defaultSpeed", 700, 0, 2000 ).SetStep( 0.05 ).SetTitle( "Default Speed" ).SetToolTip( "The speed at which the vehicle will move if there is no input in MPH" );
		Asset.AddEntry_Float( "accel", 300, 0, 10000 ).SetStep( 0.05 ).SetTitle( "Acceleration" ).SetToolTip( "For scripted helicopters this is used for determining orientation. Set it to high value for helicopter to fly leveled under regular accelerations" );
		Asset.AddEntry_Float( "rotRate", 0, 0, 20000 ).SetStep( 0.05 ).SetTitle( "Rotation Rate" ).SetToolTip( "Max rotational rate of this vehicle" );

		Asset.AddEntry_Float( "rotAccel", 0, 0, 20000 ).SetStep( 0.05 ).SetTitle( "Rotation Acceleration" ).SetToolTip( "This is only used for vehicles using radiant paths" );

		Asset.AddEntry_Float( "angDampening", 1, 0, 20000 ).SetStep( 0.05 ).SetTitle( "Velocity dampening" ).SetToolTip( "Used for planes. Dmaping scaler for velocity values" );
		Asset.AddEntry_Float( "maxAngVelocityPitch", 275, 0, 20000 ).SetStep( 0.05 ).SetTitle( "Max Angular Velocity Pitch" ).SetToolTip( "Used by planes to limit the angular velocity" );
		Asset.AddEntry_Float( "maxTorquePitch", 275, 0, 20000 ).SetStep( 0.05 ).SetTitle( "Max Torque Pitch" ).SetToolTip( "Used by planes ato limit the max torque" );

		Asset.AddEntry_Float( "rotMomentum", 0, 0, 1 ).SetStep( 0.05 ).Show( Type == "helicopter" ).SetTitle( "Rotation Momentum" ).SetToolTip( "This is the yaw momentum of the helicopter" );
		Asset.AddEntry_Float( "maxBodyPitch", 0, 0, 360 ).SetStep( 0.05 ).SetTitle( "Max Body Pitch" ).SetToolTip( "Max jolt pitch. Should be 0 for helicopters" );
		Asset.AddEntry_Float( "maxBodyRoll", 0, 0, 360 ).SetStep( 0.05 ).SetTitle( "Max Body Roll" ).SetToolTip( "Max jolt roll. Should be 0 for helicopters" );
		Asset.AddEntry_Float( "suspensionTravel", 0, 0, 20 ).SetStep( 0.05 ).SetTitle( "Suspension Travel" );
		Asset.AddEntry_CheckBox( "fakeBodyStabilizer", false ).SetTitle( "Body Stabilizer" );
		Asset.AddEntry_CheckBox( "turnInPlace", false ).SetTitle( "Turn in place" );
		Asset.AddEntry_CheckBox( "aiSlidingTurn", false ).SetTitle( "Sliding turning" ).SetToolTip( "for RAPS AI. Not meant to be used by others." );
		Asset.AddEntry_CheckBox( "aiJumpingTraversal", false ).SetTitle( "Jump across Traversals" ).SetToolTip( "for RAPS AI. Not meant to be used by others." );
		Asset.AddEntry_CheckBox( "meleeAvoidance", false ).SetTitle( "Melee attack avoidance" ).SetToolTip( "for RAPS AI. Not meant to be used by others." );
	}
	
	Asset.BeginCategory( "Player Settings" );
	{
		Asset.AddEntry_CheckBox( "isDrivable", false ).SetTitle( "Drivable" ).UpdateOnChange( true );
		Asset.AddEntry_CheckBox( "remoteControl", false ).SetTitle( "Remote Control" );
		Asset.AddEntry_CheckBox( "rotYawFromInput", false ).Show( Type == "helicopter" ).SetTitle( "Rotate Yaw From Input" ).SetToolTip( "Base yaw rotation on input rather than changes to view angles" );
		Asset.AddEntry_Int( "numberOfSeats", 0, 0, 9 ).SetTitle( "Number of Player Positions" ).SetToolTip( "Total number of usable player positions in the vehicle (including gunners)." );
		Asset.AddEntry_Int( "driverControlledGunPos", -1, -1, 4 ).SetTitle( "Driver 2nd Turret" ).SetToolTip( "Driver can fire this gunner position with the grenade button, in addition to controlling the main gun. -1 for none." );
		Asset.AddEntry_CheckBox( "doFootSteps", false ).SetTitle( "Do Foot Steps" );
	}
	
	Asset.BeginCategory( "AI Settings", 0.9, 0.3, 0.3, "Icon_asset_aitype.png" );
	{
		Asset.AddEntry_CheckBox( "isSentient", false ).SetTitle( "Is Sentient" ).SetToolTip( "Make the entity sentient so it can be targeted by other AI and has its enemy" );
		Asset.AddEntry_CheckBox( "isPathfinder", false ).SetTitle( "Is Pathfinder" ).SetToolTip( "Register the vehicle with navigation system so it can do pathfinding and position query" );
		Asset.AddEntry_CheckBox( "ignoreVortex", false ).SetTitle( "Ignore Vortex" );
		Asset.AddEntry_AssetCombo( "scriptbundlesettings", "vehiclecustomsettings" ).SetTitle( "Script Bundle Settings" ).SetToolTip( "Accessible in script on the vehicle as self.scriptbundlesettings" );
		
		Asset.AddEntry_Combo( "targetingImmuneSpecialty", "none | specialty_nottargetedbyairsupport | specialty_nottargetedbyaitank | specialty_nottargetedbyraps| specialty_nottargetedbysentry" ).SetTitle( "Do not target player with specialty" ).SetToolTip( "If a player has this speciatly ( perk ) do not target them" );
		
		Asset.AddEntry_Path( "animStateMachineName", "" ).SetRelativePath( "share/raw/animstatemachines/" ).SetTitle( "Animation State Machine" ).SetToolTip( "Animation state machine for this vehicle." );
		Asset.AddEntry_Path( "animSelectorTableName", "" ).SetRelativePath( "share/raw/animtables/" ).SetTitle( "Animation Selector Table" ).SetToolTip( "Animation Selector Table for this vehicle." );
		Asset.AddEntry_Path( "animMappingTableName", "" ).SetRelativePath( "share/raw/animtables/" ).SetTitle( "Animation Mapping Table" ).SetToolTip( "Animation Mapping Table for this vehicle." );			

        Asset.AddEntry_AssetCombo( "vehicleridersbundle", "vehicleriders" ).SetTitle( "Vehicle Riders Bundle" ).SetToolTip( "Settings for other AI getting in, out and riding vehicles. Accessible in script on the vehicle as self.vehicleridersbundle" );
        Asset.AddEntry_AssetCombo( "vehicleridersrobotbundle", "vehicleriders" ).SetTitle( "Vehicle Riders Robot Bundle" ).SetToolTip( "Settings for Robot AI getting in, out and riding vehicles. Accessible in script on the vehicle as self.vehicleridersrobotbundle" );
        Asset.AddEntry_AssetCombo( "assassinationBundle", "aiassassination" ).SetTitle( "Assassination Bundle" ).SetToolTip( "Use this script bundle when this AI gets assassinated." );
	}
	
	// -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -
	
	bool isDrivable = (Asset.GetEntryBool( "isDrivable" ) || Asset.GetEntryBool( "remoteControl" ));

	// -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -
	
	string modelsList = "worldModel | mod0 | mod1 | mod2 | mod3";
	
	// -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -
	
	// Movement and Player Settings / Seat Switch Order
	
	Asset.BeginCategory( "Player Settings.Seat Switch Order" );
	{
		Asset.AddEntry_Int( "seatSwitchOrder1", -1, -1, 12 );
		Asset.AddEntry_Int( "seatSwitchOrder2", -1, -1, 12 );
		Asset.AddEntry_Int( "seatSwitchOrder3", -1, -1, 12 );
		Asset.AddEntry_Int( "seatSwitchOrder4", -1, -1, 12 );
		Asset.AddEntry_Int( "seatSwitchOrder5", -1, -1, 12 );
		
		Asset.AddEntry_Int( "seatSwitchOrder6", -1, -1, 12 ).Show( false );
		Asset.AddEntry_Int( "seatSwitchOrder7", -1, -1, 12 ).Show( false );
		Asset.AddEntry_Int( "seatSwitchOrder8", -1, -1, 12 ).Show( false );
		Asset.AddEntry_Int( "seatSwitchOrder9", -1, -1, 12 ).Show( false );
		Asset.AddEntry_Int( "seatSwitchOrder10", -1, -1, 12 ).Show( false );		
		Asset.AddEntry_Int( "seatSwitchOrder11", -1, -1, 12 ).Show( false );
		
	}
	
	// -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -
	
	// Helicopter
	
	Asset.BeginCategory( "Helicopter" );
	{
		Asset.AddEntry_CheckBox( "vehHelicopterAccelTwardsView", false ).Show( Type == "helicopter" || Type == "plane" ).SetTitle( "Accelerate Twards Viewangles" ).SetToolTip( "Instead of accelerating in a flat plane accelerate twards the viewangles of the player." );
		Asset.AddEntry_CheckBox( "vehHelicopterAccelTwardsViewWhenFiring", false ).Show( Type == "helicopter" || Type == "plane" ).SetTitle( "Accelerate Twards Viewangles When Firing" ).SetToolTip( "Allows the vehicle to continue accelerating towards view angles even when firing (Accelerate Twards Viewangles must also be enabled)" );
		Asset.AddEntry_Float( "heliCollisionScalar", 1, 0.1, 100 ).Show( Type == "helicopter" || Type == "plane" ).SetToolTip( "The collision is based of the radius of the model wheels (dont ask).  This allows you to increase it." ).SetTitle( "Heli Collision Scalar" );
		Asset.AddEntry_Float( "maxSpeedVertical", 65, 0.1, 32000 ).Show( Type == "helicopter" || Type == "boat" ).SetToolTip( "Max vertical speed in MPH" ).SetTitle( "Max Speed Vertical" );
		Asset.AddEntry_Float( "accelVertical", 60, 0.1, 32000 ).Show( Type == "helicopter" ).SetToolTip( "Max vertical acceleration in MPH" ).SetTitle( "Max Accel Vertical" );
		Asset.AddEntry_Float( "vehHelicopterBoundsRadius", 50.0, 0.0001, 32000 ).Show( Type == "helicopter" ).SetToolTip( "The radius of the collision volume to be used when colliding with world geometry." ).SetTitle( "Bounds Radius" );
		Asset.AddEntry_Float( "vehHelicopterDecelerationFwd", 0.5, 0.0, 32000 ).Show( Type == "helicopter" ).SetToolTip( "Set the deceleration of the player helicopter (as a fraction of acceleration) in the direction the chopper is facing.  So 1.0 makes it equal to the acceleration." ).SetTitle( "Deceleration Forward" );
		Asset.AddEntry_Float( "vehHelicopterDecelerationSide", 1, 0.0, 32000 ).Show( Type == "helicopter" ).SetToolTip( "Set the side-to-side deceleration of the player helicopter (as a fraction of acceleration).  So 1.0 makes it equal to the acceleration." ).SetTitle( "Deceleration Sideways" );
		Asset.AddEntry_Float( "vehHelicopterDecelerationUp", 1, 0.0, 32000 ).Show( Type == "helicopter" ).SetToolTip( "Set the vertical deceleration of the player helicopter (as a fraction of acceleration).  So 1.0 makes it equal to the acceleration." ).SetTitle( "Deceleration Up" );
	}
	
	// -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -
	
	// Helicopter Tilt
	
	Asset.BeginCategory( "Helicopter.Tilt" );
	{
		Asset.AddEntry_Float( "viewPitchOffset", 0, -90, 90 ).Show( Type == "helicopter" ).SetTitle( "View Offset Pitch" ).SetToolTip( "Pitch offset from 0 for the default view" );
		Asset.AddEntry_Float( "tiltSpeedPitch", 1.2, 0.0, 32000 ).Show( Type == "helicopter" ).SetTitle( "Tilt Speed Pitch" ).SetToolTip( "The rate at which the player helicopter\'s tilt responds" );
		Asset.AddEntry_Float( "tiltSpeedRoll", 1.2, 0.01, 32000 ).Show( Type == "helicopter" ).SetTitle( "Tilt Speed Roll" ).SetToolTip( "The rate at which the player helicopter\'s tilt responds" );
		Asset.AddEntry_Float( "tiltFromPreviousPitch", 0, 0, 32000 ).Show( Type == "helicopter" ).SetTitle( "From Previous Pitch" ).SetToolTip( "The amount of tilt kept from the previous pitch" );
		Asset.AddEntry_Float( "tiltFromPreviousRoll", 0, 0, 32000 ).Show( Type == "helicopter" ).SetTitle( "From Previous Roll" ).SetToolTip( "The amount of tilt kept from the previous roll" );
		Asset.AddEntry_Float( "tiltFromVelocityPitch", 1, 0, 32000 ).Show( Type == "helicopter" ).SetTitle( "From Velocity Pitch" ).SetToolTip( "The amount of tilt caused by the current velocity" );
		Asset.AddEntry_Float( "tiltFromVelocityRoll", 1, 0, 32000 ).Show( Type == "helicopter" ).SetTitle( "From Velocity Roll" ).SetToolTip( "The amount of tilt caused by the current velocity" );
		Asset.AddEntry_Float( "tiltFromAccelerationPitch", 2, 0.0, 32000 ).Show( Type == "helicopter" || Type == "plane" || Type == "boat" ).SetTitle( "From Accel Pitch" ).SetToolTip( "The amount of tilt caused by acceleration" );
		Asset.AddEntry_Float( "tiltFromAccelerationRoll", 2, 0.01, 32000 ).Show( Type == "helicopter" || Type == "plane" || Type == "boat" ).SetTitle( "From Accel Roll" ).SetToolTip( "The amount of tilt caused by acceleration" );
		Asset.AddEntry_Float( "tiltFromDecelerationPitch", 2, 0, 32000 ).Show( Type == "helicopter" ).SetTitle( "From Decel Pitch" ).SetToolTip( "The amount of tilt caused by deceleration" );
		Asset.AddEntry_Float( "tiltFromDecelerationRoll", 2, 0, 32000 ).Show( Type == "helicopter" ).SetTitle( "From Decel Roll" ).SetToolTip( "The amount of tilt caused by deceleration" );
		Asset.AddEntry_Float( "vehHelicopterTiltFromControllerAxes", 0.0, 0.0, 32000 ).Show( Type == "helicopter" ).SetToolTip( "The amount of tilt caused by the desired velocity (i.e., the amount of controller stick deflection)" ).SetTitle( "Tilt From Controller" );
		Asset.AddEntry_CheckBox( "vehHelicopterPitchFromLookAxis", false ).Show( Type == "helicopter" ).SetToolTip( "Should the controller look axis control the pitch of the heli?" ).SetTitle( "Pitch From Look Axis" );
		Asset.AddEntry_Float( "vehHelicopterTiltFromFwdAndYaw", 0.0, 0.0, 32000 ).Show( Type == "helicopter" ).SetToolTip( "The amount of roll caused by yawing while moving forward." ).SetTitle( "Tilt from Forward while yawing" );
		Asset.AddEntry_Float( "vehHelicopterTiltFromFwdAndYaw_VelAtMaxTilt", 1.0, 0.0, 32000 ).Show( Type == "helicopter" ).SetToolTip( "The forward speed (as a fraction of top speed) at which the tilt due to yaw reaches is maximum value." ).SetTitle( "Max Tilt at Velocity" );
		Asset.AddEntry_Float( "vehHelicopterTiltMomentum", 0.4, 0.0001, 32000 ).Show( Type == "helicopter" ).SetToolTip( "The amount of rotational momentum the helicopter has with regards to tilting." ).SetTitle( "Tilt Momentum" );
	}

	Asset.BeginCategory( "Helicopter.Hover" );
	{
		Asset.AddEntry_Float( "vehHelicopterHoverRadius", 30, 0, 10000 ).SetTitle( "Hover Radius" ).Show( Type == "helicopter" ).SetToolTip( "Set the default hover radius." );
		Asset.AddEntry_Float( "vehHelicopterHoverSpeed", 10, 0, 10000 ).SetTitle( "Hover Speed" ).Show( Type == "helicopter" ).SetToolTip( "Set the default hover speed." );
		Asset.AddEntry_Float( "vehHelicopterHoverAccel", 5, 0, 10000 ).SetTitle( "Hover Accel" ).Show( Type == "helicopter" ).SetToolTip( "Set the default hover acceleration." );
	}

	Asset.BeginCategory( "Helicopter.Jitter" );
	{
		Asset.AddEntry_Vector3( "vehHelicopterJitterMinAccelForward", "vehHelicopterJitterMinAccelRight", "vehHelicopterJitterMinAccelUp", 0, 0, 0, -10000, 10000 ).SetTitle( "Jitter Minimum Acceleration" ).Show( Type == "helicopter" ).SetLabels( "forward", "right", "up", "" ).SetToolTip( "The minimum jitter acceleration." );
		Asset.AddEntry_Vector3( "vehHelicopterJitterMaxAccelForward", "vehHelicopterJitterMaxAccelRight", "vehHelicopterJitterMaxAccelUp", 0, 0, 0, -10000, 10000 ).SetTitle( "Jitter Maximum Acceleration" ).Show( Type == "helicopter" ).SetLabels( "forward", "right", "up", "" ).SetToolTip( "The maximum jitter acceleration." );
		Asset.AddEntry_Float( "vehHelicopterJitterMinTime", 0.0, 0.0, 10.0 ).Show( Type == "helicopter" ).SetToolTip( "The minimum amount of time the jitter will happen before changing directions." ).SetTitle( "Jitter Min Time" );
		Asset.AddEntry_Float( "vehHelicopterJitterMaxTime", 0.0, 0.0, 10.0 ).Show( Type == "helicopter" ).SetToolTip( "The maximum amount of time the jitter will happen before changing directions." ).SetTitle( "Jitter Max Time" );
		Asset.AddEntry_Float( "vehHelicopterJitterVelocityThreshold", -1.0, -1.0, 10000.0 ).Show( Type == "helicopter" ).SetToolTip( "The helicopter will only begin to apply jitter once the vehicle's velocity is below this threshold." ).SetTitle( "Jitter Velocity Threshold" );
		Asset.AddEntry_Float( "vehHelicopterJitterTiltPitchScale", 0.0, 0.0, 1.0 ).Show( Type == "helicopter" ).SetToolTip( "Adjusts the helicopter's pitch by this scale based on the forward/backward jitter" ).SetTitle( "Jitter Tilt Pitch Scale" );
		Asset.AddEntry_Float( "vehHelicopterJitterTiltRollScale", 0.0, 0.0, 1.0 ).Show( Type == "helicopter" ).SetToolTip( "Adjusts the helicopter's roll by this scale based on the left/right jitter" ).SetTitle( "Jitter Tilt Roll Scale" );
	}
	
	Asset.BeginCategory( "Helicopter.Rotors" );
	{
		Asset.AddEntry_CheckBox( "vehHelicopterQuadRotor", false ).Show( useHeliBoneControllers ).SetToolTip( "Is this a quad rotor heli?" ).SetTitle( "Quad Rotor Style" );
		
		if( useHeliBoneControllers )
		{
			useHeliFlapRotors = Asset.AddEntry_CheckBox( "vehHelicopterFlapRotor", false ).Show( useHeliBoneControllers ).UpdateOnChange( true ).SetToolTip( "Does this vehicle use rotors controlled like wing flaps?" ).SetTitle( "Wing Flap Rotors" ).GetBool();
		}
    }

