			Asset.AddEntry_Float( "nitrous_angular_drag_scale", 0.0, 0, 500 ).SetStep( 0.25 ).Show( isNitrous ).SetTitle( "Angular Drag Scale" ).SetToolTip( "Scale the default rotational resistance (air drag)" );
