	{
		Asset.AddEntry_Float( "nitrous_body_mass", 500, 1, 100000 ).SetStep( 0.05 ).Show( isNitrous ).SetTitle( "Body Mass" ).SetToolTip( "Mass in pounds, this is a video game so tanks weight 1000, do not go higher or we may have floating point problems" );	
		Asset.AddEntry_Combo( "nitrous_traction_type", "TRACTION_TYPE_ALL_WD | TRACTION_TYPE_FRONT | TRACTION_TYPE_BACK" ).SetTitle( "Traction Type" ).Show( isNitrous );
		Asset.AddEntry_CheckBox( "isFourWheelSteering", false ).Show( isNitrous ).SetTitle("Four Wheel Steering");
		Asset.AddEntry_CheckBox( "enableMiddleWheelSteering", false).Show(isNitrous).SetToolTip("Controls whether the middle wheels rotate with the front while steering.").SetTitle("Enable Middle Wheel Steering");
		Asset.AddEntry_CheckBox( "nitrous_drive_on_walls", false ).Show( isNitrous ).SetTitle("Drive on Walls").SetToolTip( "If set the vehicle will change gravity to the surface the wheels are touching" );
		Asset.AddEntry_CheckBox( "nitrous_charge_jump", false ).Show( isNitrous ).SetTitle("Charge Jump").SetToolTip( "If set then you can press and hold the jump button to jump higher" );
		Asset.AddEntry_CheckBox( "alwaysDriveForward", false ).Show( isNitrous ).SetTitle("Always Drive Forward").SetToolTip( "Only used for Halo and Strafe control modes.  Vehicle will not drive in reverse." );
		Asset.AddEntry_CheckBox( "smallVehicleCollision", false ).Show( isNitrous ).SetTitle("Small Vehicle Collision").SetToolTip( "Collide against Player User rigid bodies and not dyn ents." );
		Asset.AddEntry_Float( "nitrous_steer_angle_max", 0.6, 0, 100000 ).SetStep( 0.01 ).Show( isNitrous ).SetTitle( "Max Steer Angle" );
		Asset.AddEntry_Float( "nitrous_steer_angle_speed_scale", 0.0, 0, 1 ).SetStep( 0.01 ).Show( isNitrous ).SetTitle( "Steer Angle Speed Scale" ).SetToolTip( "Scales the max steer angle based on the speed of the vehicle relative to max speed" );
		Asset.AddEntry_Float( "nitrous_steer_speed", 5, 0, 100000 ).SetStep( 0.01 ).Show( isNitrous ).SetTitle( "Steer Speed" );
		Asset.AddEntry_Float( "nitrous_wheel_radius", 15, 1, 100000 ).SetStep( 0.05 ).Show( isNitrous ).SetTitle( "Wheel Radius" ).SetToolTip( "How big are those rims?" );
		Asset.AddEntry_Float( "nitrous_reverse_scale", 0.8, 0, 100000 ).SetStep( 0.5 ).Show( isNitrous ).SetTitle( "Reverse Speed Scale" ).SetToolTip( "Scale the max speed by this number when driving backwards" );
        Asset.AddEntry_Float( "nitrous_gravity_scale", 1.0, 0.01, 5 ).SetStep( 0.1 ).Show( isNitrous ).SetTitle( "Gravity Scale" ).SetToolTip( "Scale the gravity" );

