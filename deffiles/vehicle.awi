	// -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -
	
	// Helicopter Dogfight

	Asset.BeginCategory( "Helicopter.Dogfight" );
	{
		Asset.AddEntry_Vector3( "vehHelicopterDogfightLocalOffsetForward", "vehHelicopterDogfightLocalOffsetRight", "vehHelicopterDogfightLocalOffsetUp", 0, 0, 0, -10000, 10000 ).SetTitle( "Local Offset" ).Show( Type == "helicopter" ).SetLabels( "forward", "right", "up", "" ).SetToolTip( "The offset at which the vehicle will try to maintain in relation to its focus target." );
		Asset.AddEntry_Float( "vehHelicopterDogfightVelocityOffsetScalar", 0.0, -1000.0, 1000.0 ).Show( Type == "helicopter" ).SetToolTip( "The time in seconds to offset our dogfight target based on its velocity." ).SetTitle( "Velocity Offset Scalar" );
		Asset.AddEntry_Float( "vehHelicopterDogfightOvershootScalar", 0.0, -100000.0, 100000.0 ).Show( Type == "helicopter" ).SetToolTip( "Offsets the dogfight target position by our velocity times this scalar." ).SetTitle( "Overshoot Scalar" );
		Asset.AddEntry_Float( "vehHelicopterDogfightDesiredLocationLerpRate", 0.5, 0.0, 1000.0 ).Show( Type == "helicopter" ).SetToolTip( "The rate at which to lerp to the current desired dogfight location." ).SetTitle( "Desired Location Lerp Rate" );
		Asset.AddEntry_Float( "vehHelicopterDogfightRollRate", 1.0, 0.0, 10000.0 ).Show( Type == "helicopter" ).SetToolTip( "Adjusts how quickly the vehicle lerps to its desired roll during dogfights." ).SetTitle( "Roll Rate" );
		Asset.AddEntry_Float( "vehHelicopterDogfightSpeedFalloffDistance", 7000.0, 0.0, 32000 ).Show( Type == "helicopter" ).SetToolTip( "The vehicles max speed begins to fall off once it gets within this distance from the target offset." ).SetTitle( "Speed Falloff Distance" );
		Asset.AddEntry_Float( "vehHelicopterDogfightSpeedFalloffDistanceExponent", 1.0, 0.0, 1000.0 ).Show( Type == "helicopter" ).SetToolTip( "Determines the rate at which the speed falls off once the vehicle is within the falloff distance." ).SetTitle( "Speed Falloff Distance Exponent" );
		Asset.AddEntry_Float( "vehHelicopterDogfightControlLeewayAngle", -1.0, -1.0, 180.0 ).Show( Type == "helicopter" ).SetToolTip( "How much look control the player retains whilst focused on their dogfighting target.  Postive values override the dvar setting." ).SetTitle( "Control Leeway Angle Override" );
		Asset.AddEntry_Float( "vehHelicopterDogfightFocusDampingAngle", -1.0, -1.0, 180 ).Show( Type == "helicopter" ).SetToolTip( "Dampens the angular velocity when the delta angle to the focus target is below this threshold.  Postive values override the dvar setting." ).SetTitle( "Focus Damping Angle Override" );
		Asset.AddEntry_Float( "vehHelicopterDogfightFocusDampingAngleExponent", -1.0, -1.0, 1000.0 ).Show( Type == "helicopter" ).SetToolTip( "The exponential rate at which to damp the focus speed once the angle difference is less than the damping angle.  Postive values override the dvar setting." ).SetTitle( "Focus Damping Angle Exponent Override" );
		Asset.AddEntry_Float( "vehHelicopterDogfightFocusAngleDeltaMaxRoll", 10.0, 0.0, 180.0 ).Show( Type == "helicopter" ).SetToolTip( "This value is used to lerp from 0 to the max roll by taking the current focus angle yaw delta and dividing it by this value." ).SetTitle( "Focus Angle Delta Max Roll" );
		Asset.AddEntry_Float( "vehHelicopterDogfightCameraShakeScalar", 0.0, 0.0, 10000.0 ).Show( Type == "helicopter" ).SetToolTip( "The scalar to apply to camera shake (based on the roll of the vehicle)" ).SetTitle( "Camera Shake Scalar" );
		Asset.AddEntry_Vector3( "vehHelicopterDogfightCameraOffsetForward", "vehHelicopterDogfightCameraOffsetRight", "vehHelicopterDogfightCameraOffsetUp", 0, 0, 0, -10000, 10000 ).SetTitle( "Camera Offset" ).Show( Type == "helicopter" ).SetLabels( "forward", "right", "up", "" ).SetToolTip( "Adds this offset to the camera location when dogfighting." );
		Asset.AddEntry_Float( "vehHelicopterDogfightCameraLerpTime", 1.5, 0.0, 1000.0 ).Show( Type == "helicopter" ).SetToolTip( "The time to take to lerp to the dogfight camera (the first 25% of the time is spent lerping in the up axis before lerping the other axis)" ).SetTitle( "Camera Lerp Time" );
	}
	
