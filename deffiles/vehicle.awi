				Asset.AddEntry_Float( "antenna" + i + "Damp", 0.05, 0, 1 ).SetStep( 0.05 ).SetTitle( "Dampening" ).SetToolTip( "Dampening is like drag." );
				Asset.AddEntry_Float( "antenna" + i + "Length", 80, 0, 1000 ).SetStep( 5.0 ).SetTitle( "Length" ).SetToolTip( "Length of the antenna." );
				Asset.AddEntry_Float( "antenna" + i + "Gravity", 0, 0, 1000 ).SetStep( 1.0 ).SetTitle( "Gravity" ).SetToolTip( "Gravity on the antenna." );
				Asset.AddEntry_CheckBox( "useAntenna" + i + "XAxis", false ).SetTitle( "Use X Axis" ).SetToolTip( "Antennas are aligned by default to Z. Check this to use the X axis instead." );
