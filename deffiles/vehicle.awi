			Asset.AddEntry_Float( "nitrous_hover_brake_scale_factor", 0.5, 0, 50 ).SetStep( 0.01 ).Show( isNitrous ).SetTitle( "Hover Brake Scale Factor" ).SetToolTip( "The scale factor for adjust brake effect on hover vehicles." );
