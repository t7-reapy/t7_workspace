			Asset.AddEntry_Float( "nitrous_susp_spring_k", 20, 0, 100000 ).Show( isNitrous ).SetStep( 0.5 ).SetTitle( "Susp Spring K" ).SetToolTip( "Loosen those springs to get a soft ride" );
			Asset.AddEntry_Float( "nitrous_susp_damp_k", 1, 0, 100000 ).Show( isNitrous ).SetStep( 0.5 ).SetTitle( "Susp Damp K" ).SetToolTip( "Lighten up the dampening to get some more rocking" );
			Asset.AddEntry_Float( "nitrous_susp_hard_limit", 23, 0, 100000 ).Show( isNitrous ).SetTitle( "Susp Hard Limit" ).SetToolTip( "Max height the wheels can move up" );
			Asset.AddEntry_Float( "nitrous_susp_min_height", -100, -1000, 1000 ).SetStep( 0.05 ).Show( isNitrous ).SetTitle( "Susp Min Height" ).SetToolTip( "Min height that the wheels.  Use this to fix the wheels from sagging down too low when in the air" );
		}
				
		Asset.BeginCategory( "Physics Vehicle Parameters.Stability" );
		{
			Asset.AddEntry_Float( "nitrous_roll_stability", 0, -1000, 1000 ).SetStep( 0.1 ).Show( isNitrous ).SetTitle( "Roll Stability" ).SetToolTip( "This raises/lowers the contact point with the ground to provide more stability" );
			Asset.AddEntry_Float( "nitrous_pitch_stability", 0, -1000, 1000 ).SetStep( 0.1 ).Show( isNitrous ).SetTitle( "Pitch Stability" ).SetToolTip( "This raises/lowers the contact point with the ground to provide more stability in the forward direction. If 0 then uses roll stability." );
			Asset.AddEntry_Float( "nitrous_roll_resistance", 100, 0, 10000 ).SetStep( 5 ).Show( isNitrous ).SetTitle( "Roll/Pitch Resistance" ).SetToolTip( "This setting prevents large forces from flipping the vehicle, torque resistance agains pitch and roll" );
			Asset.AddEntry_Float( "nitrous_yaw_resistance", 0, 0, 10000 ).SetStep( 5 ).Show( isNitrous ).SetTitle( "Yaw Resistance" ).SetToolTip( "This setting prevents large forces from turning the vehicle, kind of like a torque resistance against yaw" );
			Asset.AddEntry_Float( "nitrous_upright_strength", 50, 0, 100000 ).SetStep( 5 ).Show( isNitrous ).SetTitle( "Upright Strength" ).SetToolTip( "This setting applies a force to hold the vehicle upright, the more it rolls the stronger the force" );
		}
		
