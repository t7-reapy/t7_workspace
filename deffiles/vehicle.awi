			Asset.AddEntry_Float( "nitrous_tire_fric_hand_brake_side", 0.25, 0, 10 ).Show( isNitrous ).SetTitle( "Friction Hand Brake Side Scale" ).SetToolTip( "Lower the wheel friction when the hand brake is applied" );
			Asset.AddEntry_Float( "nitrous_hand_brake_fake_rotation_force", 20.0, 0, 100000 ).Show( isNitrous ).SetTitle( "Hand Brake Fake Rotation" ).SetToolTip( "Apply a torque force based on the steering" );
			Asset.AddEntry_Float( "nitrous_hand_brake_redirect_force", 0.0, 0, 100 ).Show( isNitrous ).SetTitle( "Hand Brake Redirect Velocity Force" ).SetToolTip( "Redirects the sideways sliding velocity to forward.  Great for power sliding" );
			Asset.AddEntry_Float( "nitrous_tire_damp_hand", 10000, 0, 100000 ).SetStep( 0.05 ).Show( isNitrous ).SetTitle( "Tire Damp Hand Brake" ).SetToolTip( "Brake the rear wheels this much" );
