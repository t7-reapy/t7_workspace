			Asset.AddEntry_Float( "nitrous_boat_forward_fric", 0.4, 0, 10 ).SetStep( 0.05 ).SetTitle( "Forward" ).Show( isNitrous );
			Asset.AddEntry_Float( "nitrous_boat_vertical_fric", 0.5, 0, 10 ).SetStep( 0.05 ).SetTitle( "Vertical" ).Show( isNitrous );
