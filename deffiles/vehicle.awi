			Asset.AddEntry_Float( "nitrous_water_speed_max", 10, 0, 100000 ).SetStep( 0.2 ).SetTitle( "Max Water Speed" ).Show( isNitrous );
			Asset.AddEntry_Float( "nitrous_water_accel_max", 4, 0, 100000 ).SetStep( 0.2 ).SetTitle( "Max Water Accel" ).Show( isNitrous );
			Asset.AddEntry_Float( "nitrous_water_turn_accel", 0.25, 0, 100000 ).SetStep( 0.2 ).SetTitle( "Water Turn Accel" ).Show( isNitrous );
			Asset.AddEntry_Float( "nitrous_water_turn_speed_max", 0.25, 0, 100000 ).SetStep( 0.2 ).SetTitle( "Water Max Turn Speed" ).Show( isNitrous );
			Asset.AddEntry_Float( "nitrous_boat_ebrake_power", 1.5, 0, 10 ).SetStep( 0.2 ).SetTitle( "EBrake power scale" ).Show( isNitrous );
			Asset.AddEntry_Float( "nitrous_boat_speed_rise", 10, 0, 100 ).SetTitle( "Water Speed Rise" ).Show( isNitrous );
			Asset.AddEntry_Float( "nitrous_boat_speed_tilt", 10, 0, 100 ).SetTitle( "Water Speed Tilt" ).Show( isNitrous );
		}
		
		// -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -
		
