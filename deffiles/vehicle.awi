			Asset.AddEntry_Vector3( "nitrous_boat_motor_offset_x", "nitrous_boat_motor_offset_y", "nitrous_boat_motor_offset_z", 0, 0, 0, -1000, 1000 ).SetTitle( "Offset" ).SetStep( 0.05 ).Show( isNitrous );
		}
		
		// -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -
		
