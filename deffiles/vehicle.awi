			Asset.AddEntry_Float( "nitrous_tire_damp_coast", 10, 0, 100000 ).Show( isNitrous ).SetTitle( "Tire Damp Coast" ).SetToolTip( "How quickly do you want to come to a stop when coasting?" );
			Asset.AddEntry_Float( "nitrous_hand_brake_slide_time", 1, 0, 10 ).SetStep( 0.05 ).Show( isNitrous ).SetTitle( "Hand Brake Slide Time" ).SetToolTip( "How long to apply scaled hand brake friction." );
			Asset.AddEntry_Float( "nitrous_brake_to_reverse_time", 0.5, 0, 10 ).Show( isNitrous ).SetTitle( "Brake to Reverse Time" ).SetToolTip( "How long before reverse kicks after being stopped and pressing the brake." );
			Asset.AddEntry_Float( "autoHandbrakeMinSpeed", 12, 0, 100000 ).Show( isNitrous ).SetTitle( "Auto Hand Brake Min Speed" ).SetToolTip( "This only applies in the halo or strafe control modes and auto applies the hand brake if making a sharp turn (30') at a speed above this speed" );		
