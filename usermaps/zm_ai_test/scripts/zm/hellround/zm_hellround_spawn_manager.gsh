#define KILL_HELLROUND_WATCHERS_NOTIFICATION "kill_hellround_watchers"
#define KILL_HELLROUND_BAD_ITERATION_WATCHER_NOTIFICATION "kill_hellround_bad_iteration_watcher"

// Mostly for debug purpose, it disables all spawns during hellround.
#define HRSPAWN_ENABLE_SPAWNS 1

// Scaling delay of spawns of the entities
#define HRSPAWN_MIN_DELAY_ZOMBIE  0.25
#define HRSPAWN_MAX_DELAY_ZOMBIE  3.50
#define HRSPAWN_MIN_DELAY_NAPALM  5.00
#define HRSPAWN_MAX_DELAY_NAPALM 20.00
#define HRSPAWN_MIN_DELAY_DOG     1.00
#define HRSPAWN_MAX_DELAY_DOG    15.00
#define HRSPAWN_MIN_DELAY_FURY    3.00
#define HRSPAWN_MAX_DELAY_FURY   20.00
#define HRSPAWN_MIN_DELAY_WASP    2.00
#define HRSPAWN_MAX_DELAY_WASP   17.50

#define HRSPAWN_PLAYER_NUMBER_FACTOR 0.25
#define HRSPAWN_TIME_BEFORE_MIN_SPAWN_DELAY 150000 // 2.5 minutes in milliseconds
