Technique( "unlit" )
{
	state   = "state"
	source  = "ShaderWorks\sw4_2d_digitalnoise_qrdrone.fx"
	defines = "CONFIG_UNLIT" , "MTL_BLEND_MODE_REPLACE"
	vs      = VertexShader()
	{
		vertexDecl = "generic"
	}
	ps = PixelShader()
	{
		floatZSampler_C63_P0   = CodeTexture( "floatZSampler" )
		resolvedPostSun_C11_P0 = CodeTexture( "resolvedPostSun" )
	}
}
