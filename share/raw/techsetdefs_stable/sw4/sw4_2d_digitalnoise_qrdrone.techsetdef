#include "state.techsetdef"
Globals()
{
	renderFlags = RenderFlags()
	{
		is2D                = true
		
		forFX               = false
		isEmissive          = false
		
		isOpaque            = true
	}
	category          = "ShaderWorks 2D"
	availablePrefixes = ""
}
State( "state" )
{
	blendState = BlendState()
	{
		// Replace
		colorBlendFunc = add
		colorBlendSrc  = One
		colorBlendDst  = Zero
		alphaBlendFunc = add
		alphaBlendSrc  = One
		alphaBlendDst  = Zero
		writeChannels  = "rgba"
	}
	cull = "Back"
}
Sampler( "GridTexture_Sampler" )
{
	tile   = "tile both"
	filter = "mip standard (2x bilinear)"
}
Texture( "GridTexture" )
{
	image    = Image( "bw_grid" )
	semantic = "diffuseMap"
}
#if TOOLSGFX == "1"
Texture( "floatZSampler_C63_P0" )
{
	image = Image( < sw_codetexture_00 > )
	tweak = Tweak()
	{
		default = "sw4\\textures\\colin\\rts_holoview\\2_depth_bufferlow.jpg"
	}
}
#endif
Sampler( "floatZSampler_C63_P0_sampler" )
{
	tile   = "tile both*"
	filter = "mip more expensive (2x trilinear)"
}
Sampler( "BlockNoise_Sampler" )
{
	tile   = "tile both"
	filter = "nomip nearest"
}
Texture( "BlockNoise" )
{
	image    = Image( "sam_block_noise" )
	semantic = "diffuseMap"
}
Sampler( "Lookup2_Sampler" )
{
	tile   = "tile both"
	filter = "mip standard (2x bilinear)"
}
Texture( "Lookup2" )
{
	image    = Image( "tv_lookup" )
	semantic = "diffuseMap"
}
#if TOOLSGFX == "1"
Texture( "resolvedPostSun_C11_P0" )
{
	image = Image( < sw_codetexture_01 > )
	tweak = Tweak()
	{
		default = "sw4\\textures\\colin\\rts_holoview\\1_base_background.jpg"
	}
}
#endif
Sampler( "resolvedPostSun_C11_P0_sampler" )
{
	tile   = "tile both*"
