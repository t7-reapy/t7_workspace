
#include "state"
#include "renderFlags"

Globals()
{
	category = "Filters"
}

Technique( "lit", "unlit" )
{
	state = "disable"
	source = "postfx/postfx_speedblur.hlsl"
	defines = "USE_VERTCOL 0"

	vs = VertexShader()
	{ }
	ps = PixelShader()
	{
// textures
	    pixelTexture  = CodeTexture( "codeTexture0" )
		blurTexture   = CodeTexture( "codeTexture1" )
// samplers
 		bilinearClamp = Sampler("no tile", "nomip bilinear")
	}
}
