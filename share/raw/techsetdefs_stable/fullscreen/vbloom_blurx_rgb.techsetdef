#include "state"
#include "renderFlags"

Globals()
{
	category = "Filters"
}

Technique( "lit", "unlit" )
{
	state = "disable"

	vs = VertexShader()
	{
		source = "vbloom_blurx_rgb.hlsl"
	}
	ps = PixelShader()
	{
		source = "vbloom_blurx_rgb.hlsl"

		biLinearClamp = Sampler("no tile", "nomip bilinear")
	}
}
