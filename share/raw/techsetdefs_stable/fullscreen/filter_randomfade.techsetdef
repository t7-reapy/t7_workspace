
#include "state"
#include "renderFlags"

Globals()
{
	category = "Filters"
}


Technique( "lit", "unlit" )
{
	state = "disable"

	vs = VertexShader()
	{
	  	defines = "USE_VERTCOL 0","USE_SCRIPTVECTOR 1"
       		source = "postfx/postfx_randomfade.hlsl"
	}
	ps = PixelShader()
	{
		defines = "USE_VERTCOL 0","USE_SCRIPTVECTOR 1"
		source = "postfx/postfx_randomfade.hlsl"
		colorMapSampler  = CodeTexture( "resolvedScene" )
	}
}
