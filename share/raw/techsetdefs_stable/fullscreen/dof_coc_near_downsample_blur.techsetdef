#include "state"
#include "renderFlags"

Globals()
{
	category = "Filters"
}

Technique( "lit", "unlit" )
{
	state = "disable"
	source = "DOF/dof_coc_near_downsample_blur.hlsl"

	vs = VertexShader()
	{
	}
	ps = PixelShader()
	{
		// textures
		codeTexture0 = CodeTexture( "codeTexture0" )
		// samplers
		bilinearClamp = Sampler("no tile", "nomip bilinear")
	}
}
