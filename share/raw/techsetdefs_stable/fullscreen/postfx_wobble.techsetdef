
#include "state"
#include "renderFlags"

Globals()
{
	category = "Filters"
}


Technique( "lit", "unlit" )
{
	state = "disable"

	vs = VertexShader()
	{
		source = "postfx/postfx_wobble.hlsl"
		defines = "USE_VERTCOL 0"
	}
	ps = PixelShader()
	{
		source = "postfx/postfx_wobble.hlsl"
		defines = "USE_VERTCOL 0"
		
		colorMapSampler  = CodeTexture( "feedback" )

	        // samplers
 		bilinearClamp = Sampler("no tile", "nomip bilinear")
	}
}
