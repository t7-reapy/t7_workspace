#include "state"
#include "renderFlags"

Globals()
{
	category = "Filters"
}

Technique( "lit", "unlit" )
{
	state = "disable"

	defines = "TEXCOORD_OFFSET 0", "TEMPORAL_FILTER 0"

	vs = VertexShader()
	{
		source = "ssao_denoiser.hlsl"
	}

	ps = PixelShader()
	{
		source = "ssao_denoiser.hlsl"

		depthTex0 = CodeTexture( "codeTexture0" )
		aoTex = CodeTexture( "codeTexture5" )

		linearSampler = Sampler( "no tile", "nomip bilinear" )
	}
}
