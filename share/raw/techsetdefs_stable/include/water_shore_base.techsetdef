float1( "horizonDistance" )
{
	x = <cg15_w>
	tweak = Tweak()
	{
		category	= "Surface Parameters"
		title		= "Horizon Distance"
		default		= "1000"
		range		= "100.0", "50000.0", "100"
		sortindex	= 17
	}
}

float4("controlVar0")
{
	x = "2.0 / (<cg14_x> * <cg14_x>) - 2.0"
	y = "2.0 / (<cg14_y> * <cg14_y>) - 2.0"
	z = "((1.000293 - <cg14_w>) / (1.000293 + <cg14_w>))*((1.000293 - <cg14_w>) / (1.000293 + <cg14_w>))"
	w = "1.0 - (((1.000293 - <cg14_w>) / (1.000293 + <cg14_w>))*((1.000293 - <cg14_w>) / (1.000293 + <cg14_w>)))"
}

float4("controlVar1")
{
	x = "<cg14_z> / (<cg14_x> * <cg14_x>)"
	y = "(1.0 - <cg14_z>) / (<cg14_y> * <cg14_y>)"
	z = <cg15_y>
	w = <cg15_z>
}

float2("horizonControl")
{
	x = "-1.0 / (1.61803398875 * <cg15_w>)"	//	(sqrt(5) + 1) / 2 - why?
	y = "1.0 / 1.61803398875"
}

Sampler( "normalSampler" )
{
	tile = <tileNormal>
	filter = <filterNormal>
	tweak = Tweak()
	{
		category  = "Normal"
		sortindex = 10
	}
}

Texture( "normalMap" )
{
	image = Image( <normalMap, $identitynormalmap> )
	semantic = "normalMap"
	tweak = Tweak()
	{
		category  = "Normal"
		title     = "Main Normal Map"
		sortindex = 11
	}
}

float4( "shoreUVControl" )
{
	x = "1.0 / <cg13_x>"
	y = "1.0 / <cg13_y>"
	z = "<cg13_z>"
	w = "<cg13_w>"
	tweak = Tweak()
	{
		category  = "Shore"
		title     = "Shore control (scale U,V, offset U,V)"
		sortindex	= "30"
	}
}

Texture( "colorMap" )
{
	ref = true
	image = Image( <colorMap, $white_diffuse> )
	semantic = "diffuseMap"
	tweak = Tweak()
	{
		category  = "Shore"
		title     = "Shore Map"
		sortindex = "0"
	}
}

Sampler( "colorSampler" )
{
	tile = <tileColor>
	filter = <filterColor>
	tweak = Tweak()
	{
		category  = "Shore"
		sortindex = 1
	}
}

