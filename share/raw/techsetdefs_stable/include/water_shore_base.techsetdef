#include "lit_base_shaders"
#include "foam_base"

Sampler( "bilinearClamp" )
{
	tile   = "no tile"
	filter = "linear (mip none)"
}
Sampler( "bilinearTile" )
{
	tile   = "tile both"
	filter = "linear (mip none)"
}

Texture( "controlMap" )
{
	// TODO: Composite
	image = Image( <colorMap08,$white> )
	tweak = Tweak()
	{
		category  = "Control"
		title     = "Control Map"
		sortindex = 0
	}
}

Bool( "useFoam" )
{
	value = <foamMapEnable>
	tweak = Tweak()
	{
		category  = "Control"
		title     = "Use foam"
		sortindex = "1"
	}
}

Bool( "useVertexWaves" )
{
	value = <waterVertexGerstnerWaves>
	tweak = Tweak()
	{
		category  = "Control"
		title     = "Use vertex (Gerstner) waves"
		sortindex = "2"
	}
}

float1( "lobeA" )
{
	x = <cg14_x>
	tweak = Tweak()
	{
		category	= "Surface Parameters"
		title		= "Specular Roughness Lobe A"
		default		= "0.05"
		range		= "0.005", "1.0", "0.005"
		sortindex	= 10
	}
}

float1( "lobeB" )
{
	x = <cg14_y>
	tweak = Tweak()
	{
		category	= "Surface Parameters"
		title		= "Specular Roughness Lobe B"
		default		= "0.5"
		range		= "0.005", "1.0", "0.005"
		sortindex	= 11
	}
}

float1( "lobeAWeight" )
{
	x = <cg14_z>
	tweak = Tweak()
	{
		category	= "Surface Parameters"
		title		= "Specular Roughness Lobe A Weighting"
		default		= "0.35"
		range		= "0.005", "1.0", "0.005"
		sortindex	= 12
	}
}

float1( "indexOfRefraction" )
{
	x = <cg14_w>
	tweak = Tweak()
	{
		category	= "Surface Parameters"
		title		= "Index of refraction of water"
		default		= "1.33"
		range		= "0.5", "10.0", "0.1"
		sortindex	= 13
	}
}

