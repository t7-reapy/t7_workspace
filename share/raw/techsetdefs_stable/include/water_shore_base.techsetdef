float4( "wave0K" )
{
	x = "cos(radians(<waterVertexGerstnerWaveAngle0>)) * 6.2831853 / <waterVertexGerstnerWaveWavelength0>"
	y = "sin(radians(<waterVertexGerstnerWaveAngle0>)) * 6.2831853 / <waterVertexGerstnerWaveWavelength0>"
	z = "cos(radians(<waterVertexGerstnerWaveAngle0>))"
	w = "sin(radians(<waterVertexGerstnerWaveAngle0>))"
}

float4( "wave1K" )
{
	x = "cos(radians(<waterVertexGerstnerWaveAngle1>)) * 6.2831853 / <waterVertexGerstnerWaveWavelength1>"
	y = "sin(radians(<waterVertexGerstnerWaveAngle1>)) * 6.2831853 / <waterVertexGerstnerWaveWavelength1>"
	z = "cos(radians(<waterVertexGerstnerWaveAngle1>))"
	w = "sin(radians(<waterVertexGerstnerWaveAngle1>))"
