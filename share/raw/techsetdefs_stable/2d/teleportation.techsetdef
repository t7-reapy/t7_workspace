#include "state"
#include "renderFlags"

Globals()
{
	category = "2d"
	renderFlags = "none"
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

Sampler( "trilinearSampler" )
{
	tile   = "tile both*"
	filter = "mip more expensive (2x trilinear)"
}
Sampler( "bilinearClampSampler" )
{
	tile   = "tile horizontal"
	filter = "linear (mip none)"
}

Texture( "lookupTexture" )
{
	image = Image( <alphaRevealMap, $half_reveal> )
	semantic = "revealMap"
	tweak = Tweak()
	{
		category  = "Hole Glow"
		title     = "Lookup Map"
		sortindex = "10"
	}
}

Texture( "spaceTexture" )
{
	image = Image( <colorMap06, $white> )
	tweak = Tweak()
	{
		category  = "Space Anus"
		title     = "Space Background Map"
		sortindex = "20"
	}
}

