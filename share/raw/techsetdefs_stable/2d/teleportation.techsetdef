// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

Technique( "unlit" )
{
	state = "replace + nocull"
	vs = VertexShader()
	{
		source = "postFX/2d_teleportation.hlsl"
	}
	ps = PixelShader()
	{
		source = "postFX/2d_teleportation.hlsl"
		frameBuffer = CodeTexture( "resolvedScene" )
	}
}
