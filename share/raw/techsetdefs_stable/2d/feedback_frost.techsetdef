#include "state"
#include "renderFlags"

Globals()
{
	category = "2d"
	renderFlags = "none"
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

Sampler( "bilinearSampler" )
{
	tile   = "tile both*"
	filter = "linear (mip none)"
}

Texture( "colorMap" )
{
	image    = Image( <colorMap, $white> )
	tweak    = Tweak()
	{
		category	= "Color"
		title		= "Color Map"
		sortindex	= "10"
	}
}

Texture( "normalMap" )
{
	image    = Image( <normalMap, $normal> )
	tweak    = Tweak()
	{
		category	= "Refraction"
		title		= "Normal Map"
		sortindex	= "10"
	}
}

Texture( "revealMap" )
{
	image    = Image( <alphaRevealMap, $white_reveal> )
	tweak    = Tweak()
	{
		category	= "Reveal"
		title		= "Reveal Map"
		sortindex	= "10"
	}
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

float2( "colorFlipRowsCols" )
{
	x     = <cg01_x>
	y     = <cg01_y>
	tweak = Tweak()
	{
		category	= "Color"
		title		= "Flipbook (Rows, Columns)"
		sortindex	= "30"
	}
}

float1( "colorFlipTime" )
{
	x     = <cg01_z>
	tweak = Tweak()
	{
		category	= "Color"
		title		= "Flipbook Time"
		sortindex	= "40"
	}
}

Bool( "useAlphaBlend" )
{
	value = <gCheckBox00>
	tweak = Tweak()
	{
		category	= "Color"
		title		= "Use alpha blend (default is screen blend)"
		sortindex	= "50"
	}
}

float1( "alphaRevealSoftEdge" )
{
	x     = <alphaRevealSoftEdge>
	tweak = Tweak()
	{
		category	= "Reveal"
		title		= "Soft Edge"
		sortindex	= "20"
	}
}

float1( "alphaRevealRamp" )
{
	x     = <alphaRevealRamp>
	tweak = Tweak()
	{
		category	= "Reveal"
		title		= "Ramp"
		sortindex	= "30"
	}
}

float1( "refractionPixels" )
{
	x     = <cg00_x>
	tweak = Tweak()
	{
		category	= "Refraction"
		title		= "Pixel Offset"
		sortindex	= "20"
	}
}

float1( "blurPixels" )
{
	x     = <cg00_y>
	tweak = Tweak()
	{
		category	= "Framebuffer"
		title		= "Blur Width (Pixels)"
		sortindex	= "10"
	}
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

Technique( "unlit" )
{
	state = "replace + nocull"
	source = "postfx/feedback_frost.hlsl"
	vs = VertexShader() {}
	ps = PixelShader()
	{
		frameBuffer = CodeTexture( "resolvedPostSun" )
	}
}
