#include "state"
#include "renderFlags"

Globals()
{
	category = "2d"
	renderFlags = "none"
}

Technique( "unlit" )
{
	state = State() : "replace + nocull"
	{
		stencilFront = StencilState()
		{
			enable	= true
			func	= Equal
			opFail	= Keep
			opPass	= Keep
			opZFail	= Keep
		}
	}

	source = "utils/fill_ps.hlsl"
	defines = "USE_MATERIAL_COLOR"

	vs = VertexShader()	{ }
	ps = PixelShader() { }
}
