#include "lit_base"
#include "micro_tile_mix_advanced_base"

Globals()
{
	category = "Geometry Advanced"
	renderFlags = "lit deferred opaque"
	availablePrefixes = "mc/ mcs/ wc/"
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

Texture( "mixMap" ).tweak = Tweak()
{
	category  = "Base Maps"
	title     = "Mix Reveal Map1"
	sortindex = "20"
}
Texture( "mixMap1" )
{
	image = Image( <colorMap08, $white_reveal> )
	semantic = "revealMap"
	tweak = Tweak()
	{
		category  = "Base Maps"
		title     = "Mix Reveal Map2"
		sortindex = "30"
	}
}

Texture( "detailMap3" )
{
	image = Image( <colorMap04, $identitynormalmap> )
	semantic = "normalMap"
	tweak = Tweak()
	{
		category  = "Detail Maps3"
		title     = "Normal Map"
		sortindex = "20"
	}
}
Texture( "colorMapDetail3" )
{
	image = Image( <colorMap05, $white_diffuse> )
	semantic = "diffuseMap"
	tweak = Tweak()
	{
		category  = "Detail Maps3"
		title     = "Color Map"
		sortindex = "0"
	}
}
Texture( "glossMapDetail3" )
{
	image = Image( <colorMap06, $white_gloss> )
	semantic = "glossMap"
	tweak = Tweak()
	{
		category  = "Detail Maps3"
		title     = "Gloss Map"
		sortindex = "30"
	}
}
Texture( "specularMapDetail3" )
{
	image = Image( <colorMap07, $white_specular> )
	semantic = "specularMask"
	tweak = Tweak()
	{
		category  = "Detail Maps3"
		title     = "Specular Map"
		sortindex = "40"
	}
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

float2( "mixScale" ).tweak = Tweak()
{
	category  = "Base Maps"
	title     = "Mix Reveal Scale1 (X, Y)"
	sortindex = "100"
}
float2( "mixScale1" )
{
	x = <cg30_z>
	y = <cg30_w>
	tweak = Tweak()
	{
		category  = "Base Maps"
		title     = "Mix Reveal Scale2 (X, Y)"
		sortindex = "140"
	}
}

float1( "alphaRevealSoftEdge1" )
{
	x = <alphaRevealSoftEdge>
	tweak = Tweak()
	{
		category  = "Base Maps"
		title     = "Mix Reveal Soft Edge1"
		sortindex = "125"
	}
}
float1( "alphaRevealRamp1" )
{
	x = <alphaRevealRamp>
	tweak = Tweak()
	{
