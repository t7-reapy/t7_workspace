float2( "levelsInputs" )
{
	x = <levelsInputMin>
	y = <levelsInputMax>
	tweak = Tweak()
	{
		category  = "Base Maps"
		title     = "Mix1 Levels Input (Shadow, Highlight)"
		sortindex = "110"
	}
}
float2( "levelsOutputs" )
{
	x = <levelsOutputMin>
	y = <levelsOutputMax>
	tweak = Tweak()
	{
		category  = "Base Maps"
		title     = "Mix1 Levels Output (Shadow, Highlight)"
		sortindex = "120"
	}
}
float4( "levelsControls" )
{
	x = "<levelsInputMin> / 255.0" //"srgb_to_linear( <levelsInputMin> / 255.0 )"
	y = "<levelsInputMax> / 255.0" //"srgb_to_linear( <levelsInputMax> / 255.0 )"
	z = "<levelsOutputMin> / 255.0" //"srgb_to_linear( <levelsOutputMin> / 255.0 )"
	w = "<levelsOutputMax> / 255.0" //"srgb_to_linear( <levelsOutputMax> / 255.0 )"
}
float2( "levelsInputs1" )
{
	x = <levelsInputMin1>
	y = <levelsInputMax1>
	tweak = Tweak()
	{
		category  = "Base Maps"
		title     = "Mix2 Levels Input (Shadow, Highlight)"
		sortindex = "130"
	}
}
float2( "levelsOutputs1" )
{
	x = <levelsOutputMin1>
	y = <levelsOutputMax1>
	tweak = Tweak()
	{
		category  = "Base Maps"
		title     = "Mix2 Levels Output (Shadow, Highlight)"
		sortindex = "140"
	}
}
float4( "levelsControls1" )
{
	x = "<levelsInputMin1> / 255.0" //"srgb_to_linear( <levelsInputMin1> / 255.0 )"
	y = "<levelsInputMax1> / 255.0" //"srgb_to_linear( <levelsInputMax1> / 255.0 )"
	z = "<levelsOutputMin1> / 255.0" //"srgb_to_linear( <levelsOutputMin1> / 255.0 )"
	w = "<levelsOutputMax1> / 255.0" //"srgb_to_linear( <levelsOutputMax1> / 255.0 )"
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

Technique( "build shadowmap depth" ) :  "build shadowmap depth base"
{}

#if TETRAHEDRON_OMNI_SHADOWS=="1"
Technique( "build shadowmap depth planes" ) : "build shadowmap depth planes base"
{}
#endif

Technique( "build shadowmap depth layered" ) :  "build shadowmap depth layered base"
{}

Technique( "unlit" )
{
	state = "replace + depth"
	defines = "USE_COLOR_TINT", "USE_MICRO_BLEND"
	source = "techsetdef_unlit_simple.hlsl"
	vs = "vs_generic"
	ps = "ps_generic"
}

Technique( "gbuffer" )
{
	state = "gbuffer opaque"
	defines = "USE_WORLD_TILE_OFFSET", "USE_TRIPLE_MIX", "FANCY_VEHICLE_EXTRA"
	source = "gbuffer_micro_tile_triple_mix.hlsl"
	vs = "vs_generic"
	ps = "ps_generic"
}

Technique( "gbuffer motion vector" ) : "gbuffer"
{
	defines += "GENERATE_MOTION_VECTOR"
}

Technique( "debug color texel" )
{
	state = "replace + depth"
	vs = VertexShader()
	{
		source = "ToolsGfx/debug_texeldensity.hlsl"
		vertexDecl = "generic"
	}
	ps = PixelShader()
	{
		source = "ToolsGfx/debug_texeldensity.hlsl"
		defines = "DEBUG_COLOR_TEXELS"
	}
}
