#include "lit_base"
#include "emissive_base"
#include "scroll_base"
#include "flipbook_base"
#include "flicker_base"
#include "transparent_base"
#include "camo_base"

Globals()
{
	category = "Geometry Advanced"
	renderFlags = "lit transparent"
	availablePrefixes = "mc/ mcs/ wc/"
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

Texture( "emissiveMap1" ) : "emissiveMap"
{
	tweak = Tweak()
	{
		category  = "Layer1"
		title     = "Emissive Map"
		sortindex = "10"
	}
}

Texture( "emissiveMap2" )
{
	ref = true
	image = Image( <colorMap01, $white> )
	semantic = "diffuseMap", "HDR"
	tweak = Tweak()
	{
		category  = "Layer2"
		title     = "Emissive Map"
		sortindex = "10"
	}
}

Texture( "emissiveMap3" )
{
	ref = true
	image = Image( <colorMap02, $white> )
	semantic = "diffuseMap", "HDR"
	tweak = Tweak()
	{
		category  = "Layer3"
		title     = "Emissive Map"
		sortindex = "10"
	}
}

Texture( "tintMask" )
{
	image = Image( <colorMap05, $white_reveal> )
	semantic = "revealMap"
	tweak = Tweak()
	{
		category  = "Color"
		title     = "Tint Mask"
		sortindex = "20"
	}
}

