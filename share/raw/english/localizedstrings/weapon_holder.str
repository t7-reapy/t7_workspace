FILENOTES "Weapon holder to transfer a gun or put it on the side"

REFERENCE DEPOSIT
LANG_ENGLISH "^3[{+activate}]^7 [^3&&1^7] Put the weapon aside"

REFERENCE WITHDRAW
LANG_ENGLISH "^3[{+activate}]^7 [^3&&1^7] Pick up the weapon"

REFERENCE SWAP
LANG_ENGLISH "^3[{+activate}]^7 [^3&&1^7] Swap the current weapon for this weapon"

ENDMARKER