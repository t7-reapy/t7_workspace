#include "state"
#include "renderFlags"

Globals()
{
	category = "2d"
	renderFlags = "none"
	availablePrefixes = ""
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

Sampler( "bilinearClampler" )
{
	tile   = "no tile"
	filter = "nomip bilinear"
}

Texture( "revealMap" )
{
	image    = Image( <colorMap00, $white_reveal> )
	semantic = "revealMap"
	tweak    = Tweak()
	{
		category	= "Reveal"
		title		= "Reveal Map"
		sortindex	= "10"
	}
}

Texture( "diffuseMap" )
{
	image    = Image( <colorMap01, $white_diffuse> )
	semantic = "diffuseMap"
	tweak    = Tweak()
	{
		category	= "Color"
		title		= "Color Map"
		sortindex	= "10"
	}
}

Texture( "highlightMap" )
{
	image    = Image( <colorMap02, $black_diffuse> )
	semantic = "diffuseMap"
	tweak    = Tweak()
	{
		category	= "Color"
		title		= "Highlight Map"
		sortindex	= "20"
	}
}

Texture( "vignetteMap" )
{
	image    = Image( <colorMap03, $white_diffuse> )
