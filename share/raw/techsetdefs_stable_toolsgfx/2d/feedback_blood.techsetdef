Technique( "unlit" )
{
	state = "replace + nocull"
	source = "postfx/feedback_blood.hlsl"
	vs = VertexShader() { }
	ps = PixelShader()
	{
		frameBuffer = CodeTexture( "resolvedPostSun" )
	}
}
