float1( "scanlineScale" )
{
	x = <cg00_x>
	tweak = Tweak()
	{
		category	= "Scanlines"
		title		= "Scale"
		sortindex	= "20"
		default		= "1.0"
		range		= "1.0", "4096", "0.01"
	}
}

