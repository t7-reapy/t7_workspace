Technique( "unlit" )
{
	state = "replace + nocull"
	source = "postfx/multiple_overlay.hlsl"
	vs = VertexShader() { }
	ps = PixelShader()
	{
		frameBuffer = CodeTexture( "resolvedPostSun" )
	}
}
