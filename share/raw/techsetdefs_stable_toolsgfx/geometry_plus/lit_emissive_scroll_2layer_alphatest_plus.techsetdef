float1( "uvMotionToggle1" )
{
	x = <uvMotionToggle1>
	tweak = Tweak()
	{
		category	= "UV Toggles (Fipbook - 1, Scroll/Rotate - 0)"
		title		= "Layer1"
		sortindex	= "10"
	}
}

