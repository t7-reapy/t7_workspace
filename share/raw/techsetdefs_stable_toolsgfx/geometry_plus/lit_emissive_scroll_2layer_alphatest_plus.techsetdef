#include "lit_base_mid"
#include "emissive_base"
#include "scroll_base"
#include "flipbook_base"
#include "flicker_base"
#include "camo_base"

Globals()
{
	category = "Geometry Plus"
	renderFlags = "lit forward opaque"
	availablePrefixes = "mc/ mcs/ wc/"
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

Texture( "tintMask" )
{
	image = Image()
	{
		map = <colorMap10, $white_reveal>
	}
	semantic = "revealMap"
	tweak = Tweak()
	{
		category  = "Color"
		title     = "Tint Mask"
		sortindex = "20"
	}
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

Texture( "emissiveMap1" ) : "emissiveMap"
{
	tweak = Tweak()
	{
		category  = "Layer1"
		title     = "Emissive Map"
		sortindex = "10"
	}
}

Texture( "emissiveMap2" )
{
	ref = true
	image = Image( <colorMap01, $white> )
	semantic = "diffuseMap", "HDR"
	tweak = Tweak()
	{
		category  = "Layer2"
		title     = "Emissive Map"
		sortindex = "10"
	}
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

float2( "commonScale" )
{
	x = <cg12_x>
	y = <cg12_y>
	tweak = Tweak()
	{
		category	= "Color"
		title		= "Scale (U, V)"
		sortindex	= "80"
		default		= "1.0"
		range		= "1.0", "128.0", "0.01"
	}
}

