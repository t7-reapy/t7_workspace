State( "gbuffer normal gloss" ) : "base gbuffer decal state"
{
	blendState0 = "gbuffer albedo multiply"
	blendState1 = "gbuffer normal gloss blend"
	blendState2 = "gbuffer disable"
}

TechniqueTemplate( "base lit decal gbuffer normal gloss" ) : "base lit decal gbuffer"
{
	state = "gbuffer normal gloss"
	defines += "GBUFFER_DECAL_DISABLE_MRT2"
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

TechniqueTemplate( "vol weapon impact unlit" )
{
#if MTL_TYPE_DYN_VOL_DECAL == "1"
	state = "unlit dynamic vol decal"
#else
	state = "unlit vol decal"
#endif
	source = "vol_decal_unlit_simple.hlsl"
	defines = "USE_ALPHA_DISSOLVE"
	vs = "vs_generic"
	ps = "ps_generic"
}


TechniqueTemplate( "vol weapon impact gbuffer" )
{
#if MTL_TYPE_DYN_VOL_DECAL == "1"
	state = "gbuffer dynamic vol decal"
#else
	state = "gbuffer vol decal"
#endif
	source = "gbuffer_decal.hlsl"
	defines = "USE_ALPHA_DISSOLVE"
	vs = "vs_generic"
	ps = "ps_generic"
}

