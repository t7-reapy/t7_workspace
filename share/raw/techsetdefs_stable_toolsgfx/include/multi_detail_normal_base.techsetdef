Sampler( "detailMaskSampler" )
{
	tile = <texTile04>
	filter = <filterColor04>
	tweak = Tweak()
	{
		category  = "Detail"
		title     = "Mask"
		sortindex = "132"
	}
}

Texture( "detailNormalMask" )
{
