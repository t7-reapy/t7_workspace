Sampler( "normalSamplerTweak" ) : "normalSampler"
{
	tweak = Tweak(){ category = "Normal" }
}

Texture( "detailNormal1" )
{
	image = Image( <detailMap, $identitynormalmap> )
	semantic = "normalMap"
	tweak = Tweak()
	{
		category  = "Detail"
		title     = "Normal1 (Mask Red)"
		sortindex = "10"
	}
}
Texture( "detailNormal2" )
{
	image = Image( <colorMap01, $identitynormalmap> )
