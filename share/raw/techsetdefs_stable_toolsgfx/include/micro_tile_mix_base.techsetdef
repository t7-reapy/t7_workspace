Texture( "detailMap1" )
{
	image = Image( <detailMap, $identitynormalmap> )
	semantic = "normalMap"
	tweak = Tweak()
	{
		category  = "Detail Maps1"
		title     = "Normal Map"
		sortindex = "20"
	}
}
Texture( "detailMap2" )
{
	image = Image( <colorMap00, $identitynormalmap> )
	semantic = "normalMap"
	tweak = Tweak()
	{
		category  = "Detail Maps2"
		title     = "Normal Map"
		sortindex = "20"
	}
}

Texture( "colorMap" ).tweak = Tweak()
{
	category  = "Detail Maps1"
	title     = "Color Map"
	sortindex = "0"
}
Texture( "colorMapDetail2" )
{
	image = Image( <colorMap01, $white_diffuse> )
	semantic = "diffuseMap"
	tweak = Tweak()
	{
		category  = "Detail Maps2"
		title     = "Color Map"
		sortindex = "0"
	}
}

Sampler( "mixSampler" )
{
	tile = <tileReveal>
	filter = <filterReveal>
	tweak = Tweak()
	{
		category  = "Base Maps"
		sortindex = "30"
	}
}
Texture( "mixMap" )
{
	image = Image( <alphaRevealMap, $black_reveal> )
	semantic = "revealMap"
	tweak = Tweak()
	{
		category  = "Base Maps"
		title     = "Mix Map"
		sortindex = "20"
	}
}

Texture( "normalMap" ).tweak = Tweak()
{
	category  = "Base Maps"
	title     = "Normal Map"
	sortindex = "0"
}

