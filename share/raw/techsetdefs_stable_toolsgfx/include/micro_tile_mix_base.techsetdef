float2( "mixScale" )
{
	x = <uScale>
	y = <vScale>
	tweak = Tweak()
	{
		category  = "Base Maps"
		title     = "Mix Map Scale (X, Y)"
		sortindex = "100"
	}
}

Color( "colorTint" ).tweak = Tweak()
{
	category  = "Detail Maps1"
	title     = "Albedo Tint"
	sortindex = "10"
	color = true
}
Color( "colorTint1" )
{
	value = "srgb_to_linear( <colorTint1> )"
	tweak = Tweak()
	{
		category  = "Detail Maps2"
		title     = "Albedo Tint"
		sortindex = "10"
		color = true
	}
}

