{
	x =	"<gFoamScrollAngle0>"
	y =	"<gFoamScrollSpeed0>"
	z =	"<gFoamUVScale0>"
	tweak = Tweak()
	{
		category  = "Foam"
		title     =  "Foam UV Scroll 0 (angle, speed, scale)"
		sortindex = "57"
	}
}

