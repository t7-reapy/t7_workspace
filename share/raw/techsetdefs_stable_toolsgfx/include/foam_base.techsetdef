float4( "foamMaskScale01" )
{
	x =	"1.0 / <gFoamUVScale0>"
	y =	"1.0 / <gFoamUVScale0>"
	z =	"1.0 / <gFoamUVScale1>"
	w =	"1.0 / <gFoamUVScale1>"
}

