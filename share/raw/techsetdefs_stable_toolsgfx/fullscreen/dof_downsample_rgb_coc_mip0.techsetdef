#include "state"
#include "renderFlags"

Globals()
{
	category = "Filters"
}

Technique( "lit", "unlit" )
{
	state = "disable"
	source = "DOF/dof_downsample_rgb_coc.hlsl"

	vs = VertexShader()
	{
	}
	ps = PixelShader()
	{
		// textures
		defines = "USE_MIP0"
		codeTexture0 = CodeTexture( "codeTexture0" )
		codeTexture1 = CodeTexture( "codeTexture1" )
		// samplers
		bilinearClamp = Sampler("no tile", "nomip bilinear")
	}
}
