
#include "state"
#include "renderFlags"

Globals()
{
	category = "Filters"
}

Technique( "lit", "unlit" )
{
	state = "disable"

	vs = VertexShader()
	{
		source = "pc_resolve_floatz8.hlsl"
	}
	ps = PixelShader()
	{
		source = "pc_resolve_floatz8.hlsl"
		floatZSampler = CodeTexture( "floatZ" )
	}
}
