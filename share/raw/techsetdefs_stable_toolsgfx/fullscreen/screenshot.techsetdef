
#include "state"
#include "renderFlags"

Globals()
{
	category = "Filters"
}

Technique( "lit", "unlit" )
{
	state = "disable"

	vs = VertexShader()
	{
		source = "screenshot.hlsl"
		defines = "USE_VERTCOL 0"
	}
	ps = PixelShader()
	{
		source = "screenshot.hlsl"
		defines = "USE_VERTCOL 0"

		colorMapSampler  = CodeTexture( "codeTexture0" )
	}
}
