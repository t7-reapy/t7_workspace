#include "state"
#include "renderFlags"

Globals()
{
	category = "Filters"
}

Technique( "lit", "unlit" )
{
	state = "disable"
	vs = VertexShader()
	{
		source = "BLOOM/bloom_apply_lut.hlsl"
		// textures
		codeTexture1 = CodeTexture( "codeTexture0" )
	}
	ps = PixelShader()
	{
		defines = "USE_LENS_DISTORTION_BY 1"

		source = "BLOOM/bloom_apply_lut.hlsl"

		bilinearClamp = Sampler("no tile", "nomip bilinear")
	}
}

