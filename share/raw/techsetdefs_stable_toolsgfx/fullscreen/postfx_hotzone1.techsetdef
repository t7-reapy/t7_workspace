
#include "state"
#include "renderFlags"

Globals()
{
	category = "Filters"
}


Texture( "gridTextureA" )
{
	ref = true
	image = Image( <colorMap11, $white> )
	tweak = Tweak()
	{
		category  = "Color"
		title     = "Grid Texture A"
		sortindex = "1"
	}
}

