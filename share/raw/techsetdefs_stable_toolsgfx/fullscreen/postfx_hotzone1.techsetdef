Technique( "lit", "unlit" )
{
	state = "disable"

	vs = VertexShader()
	{
		source = "postfx/postfx_hotzone1.hlsl"
		defines = "USE_VERTCOL 0"
	}
	ps = PixelShader()
	{
		source = "postfx/postfx_hotzone1.hlsl"
		defines = "USE_VERTCOL 0"
		// textures
   	     	colorMapSampler  = CodeTexture( "feedback" )
   		codeTexture0  = CodeTexture( "codeTexture0" )
	        codeTexture1  = CodeTexture( "codeTexture1" )
		codeTexture2  = CodeTexture( "codeTexture2" )
  		// samplers
 		samplerBilinearWrap = Sampler( "tile both", "mip (1x trilinear)" )
	}
}
