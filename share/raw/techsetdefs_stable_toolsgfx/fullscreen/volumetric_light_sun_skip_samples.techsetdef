										

#include "state"
#include "renderFlags"

Globals()
{
	category = "Filters"
	renderFlags = "none"
	gameOnly = true
}

Technique( "lit", "unlit" )
{
	state = "replace"
	source = "volumetric_light_sun_skip_samples.hlsl"

	vs = VertexShader()
	{
	}

	ps = PixelShader()
	{
		depthSampler = CodeTexture( "floatZ" )
		downsampledDepth = CodeTexture( "postEffect1" )
		samplerLinear = Sampler( "tile both", "nomip bilinear", true )
		samplerLinearClamp = Sampler( "no tile", "nomip bilinear", true )

		gLitFogVolumes = CodeBuffer( "litFogVolumeBuffer" )
		volLightTexture = CodeTexture( "postEffectSrc" )

		gEsmSunShadowmapArray = CodeTexture( "postEffect0" )

		downsampledAlphaDepth = CodeTexture( "codeTexture2" )

		adaptiveTransparencyDepth = CodeTexture( "codeTexture3" )
		adaptiveTransparencyTrans = CodeTexture( "codeTexture4" )
		downSampledDepthUV = CodeTexture( "codeTexture5" )
		oitPixelAlpha = CodeTexture( "codeTexture6" )

		gTrilinearClampSampler = Sampler( "no tile", "mip (1x trilinear)", true )

		
	}
}
