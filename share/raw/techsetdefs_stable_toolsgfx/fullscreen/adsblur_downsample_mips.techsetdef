
#include "state"
#include "renderFlags"

Globals()
{
	category = "Filters"
}

Technique( "lit", "unlit" )
{
	state = "disable"
	source = "DOF/adsblur_downsample_mips.hlsl"

	vs = VertexShader()
	{
	}
	ps = PixelShader()
	{
		// textures
		sceneColor   = CodeTexture( "codeTexture0" )

		// samplers
		bilinearClamp = Sampler("no tile", "nomip bilinear")
	}
}
