
#include "state"
#include "renderFlags"

Globals()
{
	category = "Filters"
}

Technique( "lit", "unlit" )
{
	state = "add"

	vs = VertexShader()
	{
		source = "shell_shock_flashed.hlsl"
	}
	ps = PixelShader()
	{
		source = "shell_shock_flashed.hlsl"

		colorMapSampler = CodeTexture( "feedback" )
	}
}
