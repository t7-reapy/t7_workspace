
#include "state"
#include "renderFlags"

Globals()
{
	category = "Filters"
}

Technique( "lit", "unlit" )
{
	state = "disable"

	vs = VertexShader()
	{
		source = "techsetdef_filter_symmetric.hlsl"
		defines = "USE_VERTCOL 1", "HALF_TAP_COUNT 3"
	}
	ps = PixelShader()
	{
		source = "techsetdef_filter_symmetric.hlsl"
		defines = "USE_VERTCOL 1", "HALF_TAP_COUNT 3"

		colorMapSampler = CodeTexture( "feedback" )
	}
}
