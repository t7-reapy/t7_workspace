
#include "state"
#include "renderFlags"

Globals()
{
	category = "Filters"
}

Technique( "lit", "unlit" )
{
	state = "disable"

	vs = VertexShader()
	{
		source = "small_blur.hlsl"
	}
	ps = PixelShader()
	{
		source = "small_blur.hlsl"

		colorMapSampler = CodeTexture( "feedback" )
	}
}
