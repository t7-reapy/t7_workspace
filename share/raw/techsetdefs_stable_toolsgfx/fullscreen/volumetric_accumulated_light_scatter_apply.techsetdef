										

#include "state"
#include "renderFlags"

Globals()
{
	category = "Filters"
	renderFlags = "none"
}

Technique( "lit", "unlit" )
{
#if PLAT_PC == "1"
	state = "disable"
#else
	state = "premul color"
#endif

	vs = VertexShader()
	{
		source = "volumetric_accumulated_light_scatter_apply.hlsl"
	}

	ps = PixelShader()
	{
		source = "volumetric_accumulated_light_scatter_apply.hlsl"

		floatZSampler = CodeTexture( "floatZ" )
		depthSamplerState = Sampler( "no tile", "nomip nearest" )

		volumeLightTexture = CodeTexture( "postEffect0" )
		volumeLightSamplerState = Sampler( "no tile", "nomip bilinear" )

		downsampledDepth = CodeTexture( "postEffect1" )
		volumetricAccumulatedLightScatter = CodeTexture( "codeTexture3" )

#if PLAT_PC == "1"
		blendTexture = CodeTexture( "feedback" )
#endif
	}
}
