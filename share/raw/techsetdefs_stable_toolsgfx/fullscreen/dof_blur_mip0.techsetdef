#include "state"
#include "renderFlags"

Globals()
{
	category = "Filters"
}

Technique( "lit", "unlit" )
{
	state = "disable"
	source = "DOF/dof_blur_mip.hlsl"

	vs = VertexShader()
	{
		defines = "USE_MIP_ZERO"
		codeTexture0 = CodeTexture( "codeTexture0" )
	}
	ps = PixelShader()
	{
		defines = "USE_MIP_ZERO"
		// textures
		codeTexture0 = CodeTexture( "codeTexture0" )
		codeTexture1 = CodeTexture( "codeTexture1" )
		codeTexture2 = CodeTexture( "codeTexture2" )
		// samplers
		nearestClamp = Sampler("no tile", "nomip nearest")
		bilinearClamp = Sampler("no tile", "nomip bilinear")
		
	}
}
