
#include "state"
#include "renderFlags"

Globals()
{
	category = "Filters"
}

Technique( "lit", "unlit" )
{
	state = "disable"

	vs = VertexShader()
	{
		source = "resample_final.hlsl"
	}
	ps = PixelShader()
	{
		defines = "LINEAR_2_SRGB"
		source = "resample_final.hlsl"
	}
}
