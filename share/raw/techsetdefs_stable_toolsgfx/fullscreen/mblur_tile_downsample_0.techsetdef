#include "state"
#include "renderFlags"

Globals()
{
	category = "Filters"
}


Technique( "lit", "unlit" )
{
	state = "disable"

	vs = VertexShader()
	{
		source = "postfx/mblur_tile_downsample_0.hlsl"
	}
	ps = PixelShader()
	{
		source = "postfx/mblur_tile_downsample_0.hlsl"

		// textures
		codeTexture0 = CodeTexture( "codeTexture0" )

		// samplers
		//bilinearClamp = Sampler("no tile", "nomip bilinear")
		pointClamp = Sampler("no tile", "nomip nearest")
	}
}
