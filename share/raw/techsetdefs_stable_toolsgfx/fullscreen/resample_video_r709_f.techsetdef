#include "state"
#include "renderFlags"

Globals()
{
	category = "Filters"
}

Technique( "lit", "unlit" )
{
	state = "disable"

	vs = VertexShader()
	{
		source = "resample_video_r709_f.hlsl"
	}
	ps = PixelShader()
	{
		source = "resample_video_r709_f.hlsl"
		// textures
		codeTexture0 = CodeTexture( "codeTexture0" )
		// samplers
		bilinearClamp = Sampler("no tile", "nomip bilinear")
	}
}
