
#include "state"
#include "renderFlags"

Globals()
{
	category = "Filters"
}


Technique( "lit", "unlit" )
{
	state = "disable"
	source = "DOF/scene_blur_y.hlsl"

	vs = VertexShader()
	{
	}
	ps = PixelShader()
	{
		// samplers
		bilinearClamp = Sampler("no tile", "nomip bilinear")
	}
}
