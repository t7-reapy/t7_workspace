float4( "scanlineConsts" )
{
	x	= <cg28_z>
	y	= <cg28_w>
	z	= <cg29_x>
	w	= <cg29_y>
	tweak = Tweak()
	{
		category	= "Emissive"
		title		= "Scanline (Sharpness, Contrast, Speed, Width )"
		sortindex	= "100"
		default		= "1.0", "1.0", "0.17", "100"
		range		= "-128.0", "128.0", "0.01"
	}
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

Technique( "unlit" )
{
#if TOOLSGFX == "1"
	state	= "blend + depth"
#else
	state	= "replace + depth"
#endif
	defines = "USE_EMISSIVE"
	source = "techsetdef_unlit_simple.hlsl"
	vs = "vs_generic"
	ps = "ps_generic"
}

Technique( "lit" )
{
#if TOOLSGFX == "1"
	state	= "blend + depth"
#else
	state	= "replace + depth"
#endif
	defines = "BASE_TEXTURES", "USE_COLOR_TINT", "USE_SCROLL_ROTATE_UVS", "USE_FLIPBOOK_UVS", "USE_EMISSIVE_FLICKER"
	source = "specialty/lit_emissive_clone.hlsl"
	vs = "vs_generic"
	ps = PixelShader() : "ps_generic"
	{
	#if TOOLSGFX != "1"
		frameBuffer = CodeTexture( "resolvedPostSun" )
	#endif
	}
}

//#if TOOLSGFX == "1"
Technique( "oit" ) : "lit"
{
	state = "fallback + depth + rez"
	defines += "USE_OIT"
}
//#endif

Technique( "debug color texel" )
{
#if TOOLSGFX == "1"
	state	= "blend + depth"
#else
	state	= "replace + depth"
#endif
	source = "ToolsGfx/debug_texeldensity.hlsl"
	vs = "vs_generic"
	ps = PixelShader() : "ps_generic"
	{
		defines = "DEBUG_COLOR_TEXELS"
	}
}
