#include "lit_base_shaders"
#include "shadowmap_technique_base"
#include "transparent_shadow_base"
#include "emissive_base"
#include "flipbook_base"
#include "flicker_base"
#include "color_base"
#include "transparent_base"

Globals()
{
	category = "Specialty"
	renderFlags = "lit transparent distortion"
	availablePrefixes = "mc/ mcs/ wc/"
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

Sampler( "colorSampler" ).tweak = Tweak()
{
	category  = "Emissive"
	sortindex = "18" // leave some indices to have other color maps (need 2 indices - tile + filter)
}
Texture( "colorMap" ).tweak = ""
Color( "colorTint" ).tweak = ""

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

Color( "emissiveTint1" ).tweak = Tweak( "Emissive", "Tint State1", "10" )
float1( "hdrScale" ).tweak = Tweak( "Emissive", "HDR Scale", "50" )
float1( "emissiveFalloffPower" ).tweak = Tweak( "Emissive", "Falloff", "60" )

Color( "tint1" )
{
	value = "srgb_to_linear( <colorTint2> )"
	tweak = Tweak()
	{
		category  = "Emissive"
		title     = "Tint State 2"
		sortindex = "20"
		color = true
	}
}
Color( "tint2" )
{
	value = "srgb_to_linear( <colorTint3> )"
	tweak = Tweak()
	{
		category  = "Emissive"
		title     = "Tint State 3"
		sortindex = "30"
		color = true
	}
}
Color( "tint3" )
{
	value = "srgb_to_linear( <colorTint4> )"
	tweak = Tweak()
	{
		category  = "Emissive"
		title     = "Tint State 4"
		sortindex = "40"
		color = true
	}
}
float1( "frameDarken" )
{
	x = <cg00_z>
	tweak = Tweak()
	{
		category	= "Background"
		title		= "Darkening Factor"
		sortindex	= "80"
		default		= "1.0"
		range		= "0.0", "1.0", "0.01"
	}
}
float1( "warpAmount" )
{
	x = <cg00_w>
	tweak = Tweak()
	{
		category	= "Background"
