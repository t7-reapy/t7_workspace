#include "lit_base_basic"
#include "transparent_shadow_base"
#include "emissive_base"
#include "scroll_base"
#include "flicker_base"
#include "transparent_base"
#include "reveal_base"
#include "camo_base"

Globals()
{
	category = "Specialty"
	renderFlags = "lit transparent"
	availablePrefixes = "mc/ mcs/ wc/"
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

Texture( "tintMask" )
{
	image = Image( <colorMap01, $white_reveal> )
	semantic = "revealMap"
	tweak = Tweak()
	{
		category  = "Color"
		title     = "Tint Mask"
		sortindex = "20"
	}
}

Texture( "alphaMask" )
{
	image = Image( <colorMap02, $white_reveal> )
	semantic = "revealMap"
	tweak = Tweak()
	{
		category  = "Alpha Mask"
		title     = "Mask Map"
		sortindex = "10"
	}
}

Texture( "distortionMap" )
{
	image = Image( <colorMap03, $identitynormalmap> )
	semantic = "normalMap"
	tweak = Tweak()
	{
		category  = "Distortion"
		title     = "Distortion Map"
		sortindex = "10"
	}
}

Texture( "edgeFadeMap" )
{
	image = Image( <colorMap04, $white_reveal> )
	semantic = "revealMap"
	tweak = Tweak()
	{
		category  = "Edge Fade"
		title     = "Mask Map"
		sortindex = "10"
	}
}

Texture( "specularMask" )
{
	image = Image( <specColorMap, $white_specular> )
	semantic = "specularMask"
	tweak = Tweak()
	{
		category  = "Specular and Gloss"
		title     = "Specular Mask"
		sortindex = "10"
	}
}

