// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

uint1( "extracamSelect" )
{
	x = <sw_static_int_00>
	tweak = Tweak()
	{
		category  = "Extra Cam"
		title	  = "Camera Index"
		sortindex = "1"
		default   = "1"
		range     = "1", "4", "1"
	}
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

Technique( "lit" )
{
	state = "replace + depth"
	source = "specialty/extracam_multiple_overlay.hlsl"
	vs = VertexShader() { }
	ps = PixelShader()
	{
		extracamTexture1 = CodeTexture( "extracamTexture1" )
	  	extracamTexture2 = CodeTexture( "extracamTexture2" )
	  	extracamTexture3 = CodeTexture( "extracamTexture3" )
	  	extracamTexture4 = CodeTexture( "extracamTexture4" )
	}
}
