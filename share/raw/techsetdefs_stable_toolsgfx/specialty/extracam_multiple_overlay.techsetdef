#include "state"
#include "renderFlags"

#if TOOLSGFX != "1"
Globals()
{
	category = "Specialty"
	renderFlags = "emissive opaque"
	availablePrefixes = "mc/ mcs/ wc/"
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

Sampler( "bilinearSampler" )
{
	tile   = "tile both*"
	filter = "linear (mip linear)"
}
Sampler( "bilinearClampler" )
{
	tile   = "no tile"
	filter = "nomip bilinear"
}

Texture( "colorMap" )
{
	image    = Image( <colorMap, $white> )
	tweak    = Tweak()
	{
		category	= "Color"
		title		= "Color Map"
		sortindex	= "10"
	}
}

Texture( "scanlineMap" )
{
	image    = Image( <colorMap00, $white> )
	tweak    = Tweak()
