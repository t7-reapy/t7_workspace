#include "lit_base_basic"
#include "transparent_shadow_base"
#include "emissive_base"
#include "scroll_base"
#include "flipbook_base"
#include "flicker_base"
#include "transparent_base"

Globals()
{
	category = "Specialty"
	renderFlags = "lit transparent"
	availablePrefixes = "mc/ mcs/ wc/"
}

// - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

Texture( "tintMask" )
{
	image = Image()
	{
		map = <colorMap01, $white_reveal>
	}
	semantic = "revealMap"
	tweak = Tweak()
	{
		category  = "Color"
		title     = "Tint Mask"
		sortindex = "20"
	}
}

Texture( "alphaMask" )
{
	image = Image()
	{
		map = <colorMap02, $white_reveal>
	}
	semantic = "revealMap"
	tweak = Tweak()
	{
		category  = "Alpha Mask"
		title     = "Mask Map"
		sortindex = "10"
	}
}

Texture( "distortionMap" )
{
	image = Image()
	{
		map = <colorMap03, $identitynormalmap>
	}
	semantic = "normalMap"
	tweak = Tweak()
	{
		category  = "Distortion"
		title     = "Distortion Map"
		sortindex = "10"
	}
}

