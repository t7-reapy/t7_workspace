{
	x     = <cg06_x>
	y     = <cg06_y>
	z     = <cg06_z>
	w     = <cg06_w>
	tweak = Tweak()
	{
		title     = "HeatmapNightColor"
		sortindex = "0"
		default   = "0.076531", "0.347866", "0.535714", "1.000000"
		range     = "-1e+009", "1e+009", "0.01"
		color     = false
	}
}
