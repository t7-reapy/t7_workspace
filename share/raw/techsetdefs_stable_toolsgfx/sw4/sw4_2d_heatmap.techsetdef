float1( "Power" )
{
	x     = <cg02_x>
	tweak = Tweak()
	{
		title     = "Power"
		sortindex = "0"
		default   = "3.500000"
		range     = "-1e+009", "1e+009", "0.01"
		color     = false
	}
}
Technique( "unlit" )
{
	state   = "state"
	source  = "ShaderWorks\sw4_2d_heatmap.fx"
	defines = "CONFIG_UNLIT" , "MTL_BLEND_MODE_BLEND"
	vs      = VertexShader()
	{
		defines    = "USE_VERTCOL 1"
		vertexDecl = "generic"
	}
	ps = PixelShader()
	{
		heatmapSampler_C3_P0 = CodeTexture( "heatmapSampler" )
	}
}
