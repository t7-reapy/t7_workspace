{
	x     = <cg05_x>
	y     = <cg05_y>
	z     = <cg05_z>
	w     = <cg05_w>
	tweak = Tweak()
	{
		title     = "HeatmapColor"
		sortindex = "0"
		default   = "0.214286", "0.678571", "1.000000", "1.000000"
		range     = "-1e+009", "1e+009", "0.01"
		color     = false
	}
}
float1( "NoiseScale" )
{
	x     = <cg04_x>
	tweak = Tweak()
	{
		title     = "NoiseScale"
		sortindex = "0"
		default   = "0.250000"
		range     = "-1e+009", "1e+009", "0.01"
		color     = false
	}
}
float1( "NoiseSpeed" )
{
	x     = <cg03_x>
	tweak = Tweak()
	{
		title     = "NoiseSpeed"
		sortindex = "0"
		default   = "0.500000"
		range     = "-1e+009", "1e+009", "0.01"
		color     = false
	}
