Technique( "unlit" )
{
	state   = "state"
	source  = "ShaderWorks\sw4_2d_sonar_attachment.fx"
	defines = "CONFIG_UNLIT" , "MTL_BLEND_MODE_REPLACE"
	vs      = VertexShader()
	{
		vertexDecl = "generic"
	}
	ps = PixelShader()
	{
		sonarColorSampler_C1_P0 = CodeTexture( "sonarColorSampler" )
		floatZSampler_C2_P0     = CodeTexture( "floatZSampler" )
	}
}
