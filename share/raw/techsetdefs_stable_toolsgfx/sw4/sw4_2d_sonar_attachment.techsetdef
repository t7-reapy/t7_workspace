#include "state.techsetdef"
Globals()
{
	renderFlags = RenderFlags()
	{
		is2D                = true
		
		forFX               = false
		isEmissive          = false
		
		isOpaque            = true
	}
	category          = "ShaderWorks 2D"
	availablePrefixes = ""
}
State( "state" )
{
	blendState = BlendState()
	{
		// Replace
		colorBlendFunc = add
		colorBlendSrc  = One
		colorBlendDst  = Zero
		alphaBlendFunc = add
		alphaBlendSrc  = One
		alphaBlendDst  = Zero
		writeChannels  = "rgba"
	}
	cull = "Back"
}
Sampler( "LookupMap_Sampler" )
{
	tile   = "tile both"
	filter = "mip standard (2x bilinear)"
}
Texture( "LookupMap" )
{
	image    = Image( <colorMap07> )
	semantic = "diffuseMap"
	tweak    = Tweak()
	{
		title     = "Tearing Lookup Map"
		category  = "Tearing"
		sortindex = "35"
		default   = "sw4\\textures\\rts_holograph_distortion.tif"
	}
}
