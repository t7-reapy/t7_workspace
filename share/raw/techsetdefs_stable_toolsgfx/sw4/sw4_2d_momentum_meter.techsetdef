#include "state.techsetdef"
Globals()
{
	renderFlags = RenderFlags()
	{
		is2D                = true
		
		forFX               = false
		isEmissive          = false
		
		isTransparent       = true
	}
	category          = "ShaderWorks 2D"
	availablePrefixes = ""
}
State( "state" )
{
	blendState = BlendState()
	{
		// Blend
		colorBlendFunc = add
		colorBlendSrc  = srcAlpha
		colorBlendDst  = invSrcAlpha
		alphaBlendFunc = add
		alphaBlendSrc  = srcAlpha
		alphaBlendDst  = invSrcAlpha
		writeChannels  = "rgba"
	}
	cull = "None"
}
float4( "TickMarkColorAndHarshness" )
{
	x     = <cg03_x>
	y     = <cg03_y>
	z     = <cg03_z>
	w     = <cg03_w>
	tweak = Tweak()
	{
		title     = "TickMarkColorAndHarshness"
		sortindex = "0"
		default   = "1.000000", "1.000000", "1.000000", "100.000000"
		range     = "-1e+009", "1e+009", "0.01"
		color     = false
	}
}
