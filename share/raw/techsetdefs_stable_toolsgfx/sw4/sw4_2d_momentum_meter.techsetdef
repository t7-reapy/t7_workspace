Technique( "unlit" )
{
	state   = "state"
	source  = "ShaderWorks\sw4_2d_momentum_meter.fx"
	defines = "CONFIG_UNLIT" , "MTL_BLEND_MODE_BLEND"
	vs      = VertexShader()
	{
		defines    = "USE_VERTCOL 1"
		vertexDecl = "generic"
	}
	ps = PixelShader()
	{
	}
}
