Technique( "unlit" )
{
	state   = "state"
	source  = "ShaderWorks\sw4_2d_hud_quad_rotor.fx"
	defines = "CONFIG_UNLIT" , "MTL_BLEND_MODE_ADD"
	vs      = VertexShader()
	{
		vertexDecl = "generic"
	}
	ps = PixelShader()
	{
		floatZSampler_C2_P0   = CodeTexture( "floatZSampler" )
		resolvedPostSun_C1_P0 = CodeTexture( "resolvedPostSun" )
	}
}
