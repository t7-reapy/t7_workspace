global proc WraithMesh_e59c14e4_00_BindFunc()
{
   select -r WraithMesh_e59c14e4_00;
   select -add tag_origin;
   newSkinCluster "-toSelectedBones -mi 30 -omi true -dr 5.0 -rui false";

   string $clu = findRelatedSkinCluster("WraithMesh_e59c14e4_00");

   skinPercent -tv tag_origin 1.0 $clu WraithMesh_e59c14e4_00.vtx[0:1121];
}

global proc WraithMesh_e59c14e4_01_BindFunc()
{
   select -r WraithMesh_e59c14e4_01;
   select -add tag_origin;
   newSkinCluster "-toSelectedBones -mi 30 -omi true -dr 5.0 -rui false";

   string $clu = findRelatedSkinCluster("WraithMesh_e59c14e4_01");

