   select -r WraithMesh_e59c14e4_02;
   select -add tag_origin;
   newSkinCluster "-toSelectedBones -mi 30 -omi true -dr 5.0 -rui false";

   string $clu = findRelatedSkinCluster("WraithMesh_e59c14e4_02");

